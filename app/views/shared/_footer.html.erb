<footer class="bg-brand-900 text-white">
  <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    <div class="grid gap-12 lg:grid-cols-12">
      <div class="lg:col-span-4">
        <h2 class="font-serif text-3xl font-medium text-white">AcquireTMT</h2>

        <p class="mt-4 max-w-sm text-sm leading-7 text-white/60">
          AI-assisted M&A advisory for technology, media, telecom, digital infrastructure, and tech-enabled services companies.
        </p>
      </div>

      <div class="grid gap-8 sm:grid-cols-2 lg:col-span-8 lg:grid-cols-4">
        <% {
          "Sell" => [["Sell Your TMT Business", sell_path], ["Find Buyers", tools_find_buyers_path], ["Valuation Snapshot", tools_valuation_path]],
          "Buy" => [["Buyer Network", buyers_path], ["Market Comps", tools_market_comps_path]],
          "Industries" => [["SaaS", industry_path("saas")], ["MSP / IT Services", industry_path("msp-it-services")], ["Telecom", industry_path("telecom-connectivity")], ["Digital Media", industry_path("digital-media")]],
          "Company" => [["About", about_path], ["Insights", insights_path], ["Contact", contact_path]]
        }.each do |heading, links| %>
          <div>
            <h3 class="text-sm font-bold uppercase tracking-[0.2em] text-brand-300"><%= heading %></h3>
            <ul class="mt-5 space-y-3 text-sm text-white/70">
              <% links.each do |label, path| %>
                <li><%= link_to label, path, class: "hover:text-brand-300" %></li>
              <% end %>
            </ul>
          </div>
        <% end %>
      </div>
    </div>

    <div class="mt-14 flex flex-col gap-4 border-t border-white/10 pt-6 text-sm text-white/40 sm:flex-row sm:items-center sm:justify-between">
      <p>© <%= Time.current.year %> AcquireTMT. All rights reserved.</p>

      <div class="flex flex-wrap gap-4">
        <%= link_to "Privacy", "#", class: "hover:text-brand-300" %>
        <%= link_to "Terms", "#", class: "hover:text-brand-300" %>
        <%= link_to "Disclaimer", "#", class: "hover:text-brand-300" %>
      </div>
    </div>
  </div>
</footer>