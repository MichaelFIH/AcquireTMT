<header class="sticky top-0 z-50 border-b border-white/10 bg-brand-900/95 text-white backdrop-blur">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8" data-controller="mobile-menu">
    <div class="flex h-16 items-center justify-between">
      <%= link_to root_path, class: "font-serif text-2xl font-semibold tracking-tight text-white" do %>
        AcquireTMT
      <% end %>

      <nav class="hidden items-center gap-8 text-sm font-semibold text-white/80 lg:flex">
        <%= link_to "Sell", sell_path, class: "hover:text-brand-300" %>
        <%= link_to "Buy", buyers_path, class: "hover:text-brand-300" %>
        <%= link_to "Tools", tools_find_buyers_path, class: "hover:text-brand-300" %>
        <%= link_to "Industries", industry_path("saas"), class: "hover:text-brand-300" %>
        <%= link_to "Insights", insights_path, class: "hover:text-brand-300" %>
        <%= link_to "About", about_path, class: "hover:text-brand-300" %>
        <%= link_to "Admin", admin_leads_path, class: "hover:text-brand-300" %>
      </nav>

      <%= link_to "Find Buyers", tools_find_buyers_path,
        class: "hidden rounded-sm bg-brand-300 px-5 py-2.5 text-sm font-bold text-brand-900 hover:bg-white lg:inline-flex" %>

      <button type="button"
        class="rounded-sm border border-white/20 p-2 text-white lg:hidden"
        data-action="mobile-menu#toggle"
        aria-label="Toggle menu">
        <%= lucide_icon "menu", class: "h-5 w-5" %>
      </button>
    </div>

    <div class="hidden border-t border-white/10 py-4 lg:hidden" data-mobile-menu-target="menu">
      <nav class="flex flex-col gap-2 text-sm font-semibold text-white/80">
        <% [
          ["Sell", sell_path, "briefcase-business"],
          ["Buy", buyers_path, "users"],
          ["Tools", tools_find_buyers_path, "search"],
          ["Industries", industry_path("saas"), "building-2"],
          ["Insights", insights_path, "book-open"],
          ["About", about_path, "info"],
          ["Admin", admin_leads_path, "layout-dashboard"]
        ].each do |label, path, icon| %>
          <%= link_to path, class: "flex items-center gap-3 rounded-sm px-3 py-3 hover:bg-white/10 hover:text-brand-300" do %>
            <%= lucide_icon icon, class: "h-5 w-5 text-brand-300" %>
            <span><%= label %></span>
          <% end %>
        <% end %>

        <%= link_to tools_find_buyers_path,
          class: "mt-3 flex items-center justify-center gap-2 rounded-sm bg-brand-300 px-5 py-3 font-bold text-brand-900 hover:bg-white" do %>
          <%= lucide_icon "search", class: "h-5 w-5" %>
          <span>Find Buyers</span>
        <% end %>
      </nav>
    </div>
  </div>
</header>