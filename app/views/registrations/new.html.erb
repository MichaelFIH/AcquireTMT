<% content_for :title, "Create your account" %>

<section class="flex min-h-screen items-center justify-center bg-brand-50 px-4 py-16">
  <div class="w-full max-w-md">
    <div class="text-center">
      <%= link_to root_path, class: "font-serif text-3xl font-semibold text-brand-900" do %>
        Acquire<span class="text-brand-300">TMT</span>
      <% end %>
      <h1 class="mt-6 font-serif text-3xl font-medium text-brand-900">Create your account</h1>
      <p class="mt-2 text-sm text-slate-600">Free valuation tools for sellers, curated deals for buyers.</p>
    </div>

    <div class="mt-8 rounded-sm border border-brand-100 bg-white p-8 shadow-soft">
      <%= render "shared/google_button" %>
      <%= form_with model: @user, url: sign_up_path do |f| %>
        <% if @user.errors.any? %>
          <div class="mb-5 rounded-sm border border-red-200 bg-red-50 px-4 py-3 text-sm font-semibold text-red-700">
            <%= @user.errors.full_messages.to_sentence %>
          </div>
        <% end %>

        <p class="text-sm font-semibold text-brand-900">I'm a…</p>
        <div class="mt-2 grid grid-cols-2 gap-3">
          <% [["seller", "Seller", "Value & sell my business"], ["buyer", "Buyer", "Browse curated TMT deals"]].each do |val, label, desc| %>
            <label class="cursor-pointer rounded-sm border border-brand-100 p-4 transition hover:border-brand-300 has-[:checked]:border-brand-300 has-[:checked]:bg-brand-50">
              <%= f.radio_button :role, val, class: "sr-only" %>
              <span class="block text-sm font-bold text-brand-900"><%= label %></span>
              <span class="mt-1 block text-xs leading-5 text-slate-500"><%= desc %></span>
            </label>
          <% end %>
        </div>

        <div class="mt-5 space-y-4">
          <div>
            <%= f.label :name, "Full name", class: "block text-sm font-semibold text-brand-900" %>
            <%= f.text_field :name, autocomplete: "name",
              class: "mt-1 w-full rounded-sm border border-brand-100 px-4 py-2.5 text-sm text-brand-900 focus:border-brand-300 focus:outline-none focus:ring-1 focus:ring-brand-300" %>
          </div>
          <div>
            <%= f.label :email_address, "Email", class: "block text-sm font-semibold text-brand-900" %>
            <%= f.email_field :email_address, autocomplete: "email",
              class: "mt-1 w-full rounded-sm border border-brand-100 px-4 py-2.5 text-sm text-brand-900 focus:border-brand-300 focus:outline-none focus:ring-1 focus:ring-brand-300" %>
          </div>
          <div>
            <%= f.label :password, class: "block text-sm font-semibold text-brand-900" %>
            <%= f.password_field :password, autocomplete: "new-password",
              class: "mt-1 w-full rounded-sm border border-brand-100 px-4 py-2.5 text-sm text-brand-900 focus:border-brand-300 focus:outline-none focus:ring-1 focus:ring-brand-300" %>
          </div>
          <div>
            <%= f.label :password_confirmation, "Confirm password", class: "block text-sm font-semibold text-brand-900" %>
            <%= f.password_field :password_confirmation, autocomplete: "new-password",
              class: "mt-1 w-full rounded-sm border border-brand-100 px-4 py-2.5 text-sm text-brand-900 focus:border-brand-300 focus:outline-none focus:ring-1 focus:ring-brand-300" %>
          </div>
        </div>

        <%= f.submit "Create account",
          class: "mt-6 w-full cursor-pointer rounded-sm bg-brand-300 px-5 py-3 text-sm font-bold text-brand-900 transition hover:bg-brand-500 hover:text-white" %>
      <% end %>

      <p class="mt-5 text-center text-sm text-slate-600">
        Already have an account?
        <%= link_to "Sign in", sign_in_path, class: "font-semibold text-brand-500 hover:underline" %>
      </p>
    </div>
  </div>
</section>
