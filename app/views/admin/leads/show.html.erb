<section class="bg-slate-50 py-10">
  <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
    <%= link_to "← Back to leads", admin_leads_path,
      class: "text-sm font-bold text-brand-700" %>

    <div class="mt-6 rounded-3xl border border-slate-200 bg-white p-8 shadow-soft">
      <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
        <div>
          <h1 class="text-3xl font-extrabold text-brand-900">
            <%= [@lead.first_name, @lead.last_name].compact.join(" ") %>
          </h1>

          <p class="mt-2 text-slate-600">
            <%= @lead.company_name %>
          </p>
        </div>

        <span class="inline-flex w-fit rounded-full bg-brand-50 px-4 py-2 text-sm font-bold text-brand-700">
          <%= @lead.source&.humanize %>
        </span>
      </div>

      <div class="mt-8 grid gap-6 sm:grid-cols-2">
        <div>
          <p class="text-sm font-bold text-slate-500">Email</p>
          <p class="mt-1 text-brand-900"><%= @lead.email %></p>
        </div>

        <div>
          <p class="text-sm font-bold text-slate-500">Phone</p>
          <p class="mt-1 text-brand-900"><%= @lead.phone.presence || "Not provided" %></p>
        </div>

        <div>
          <p class="text-sm font-bold text-slate-500">Company Website</p>
          <p class="mt-1 text-brand-900">
            <% if @lead.company_website.present? %>
              <%= link_to @lead.company_website, @lead.company_website,
                target: "_blank",
                rel: "noopener",
                class: "text-brand-700 font-semibold" %>
            <% else %>
              Not provided
            <% end %>
          </p>
        </div>

        <div>
          <p class="text-sm font-bold text-slate-500">Company Type</p>
          <p class="mt-1 text-brand-900"><%= @lead.company_type.presence || "Not provided" %></p>
        </div>

        <div>
          <p class="text-sm font-bold text-slate-500">Revenue Range</p>
          <p class="mt-1 text-brand-900"><%= @lead.revenue_range.presence || "Not provided" %></p>
        </div>

        <div>
          <p class="text-sm font-bold text-slate-500">EBITDA / ARR Range</p>
          <p class="mt-1 text-brand-900"><%= @lead.ebitda_range.presence || "Not provided" %></p>
        </div>

        <div>
          <p class="text-sm font-bold text-slate-500">Status</p>
          <p class="mt-1 text-brand-900"><%= @lead.status&.humanize %></p>
        </div>

        <div>
          <p class="text-sm font-bold text-slate-500">Submitted</p>
          <p class="mt-1 text-brand-900"><%= @lead.created_at.strftime("%d %b %Y, %I:%M %p") %></p>
        </div>
      </div>

      <% if @lead.message.present? %>
        <div class="mt-8 rounded-2xl bg-slate-50 p-6">
          <p class="text-sm font-bold text-slate-500">Message</p>
          <p class="mt-2 text-slate-700"><%= @lead.message %></p>
        </div>
      <% end %>
    </div>
  </div>
</section>