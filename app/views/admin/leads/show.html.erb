<section class="bg-slate-50 py-10">
  <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
    <%= link_to "← Back to leads", admin_leads_path,
      class: "text-sm font-bold text-brand-700" %>

    <% if notice.present? %>
      <p class="mt-4 rounded-2xl bg-emerald-50 px-4 py-3 text-sm font-semibold text-emerald-700"><%= notice %></p>
    <% end %>
    <% if alert.present? %>
      <p class="mt-4 rounded-2xl bg-red-50 px-4 py-3 text-sm font-semibold text-red-700"><%= alert %></p>
    <% end %>

    <div class="mt-6 rounded-3xl border border-slate-200 bg-white p-8 shadow-soft">
      <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
        <div>
          <h1 class="text-3xl font-extrabold text-brand-900">
            <%= [@lead.first_name, @lead.last_name].compact.join(" ") %>
          </h1>

          <p class="mt-2 text-slate-600">
            <%= @lead.company_name %>
          </p>
        </div>

        <span class="inline-flex w-fit rounded-full bg-brand-50 px-4 py-2 text-sm font-bold text-brand-700">
          <%= @lead.source&.humanize %>
        </span>
      </div>

      <div class="mt-8 grid gap-6 sm:grid-cols-2">
        <div>
          <p class="text-sm font-bold text-slate-500">Email</p>
          <p class="mt-1 text-brand-900"><%= @lead.email %></p>
        </div>

        <div>
          <p class="text-sm font-bold text-slate-500">Phone</p>
          <p class="mt-1 text-brand-900"><%= @lead.phone.presence || "Not provided" %></p>
        </div>

        <div>
          <p class="text-sm font-bold text-slate-500">Company Website</p>
          <p class="mt-1 text-brand-900">
            <% if @lead.company_website.present? %>
              <%= link_to @lead.company_website, @lead.company_website,
                target: "_blank",
                rel: "noopener",
                class: "text-brand-700 font-semibold" %>
            <% else %>
              Not provided
            <% end %>
          </p>
        </div>

        <div>
          <p class="text-sm font-bold text-slate-500">Company Type</p>
          <p class="mt-1 text-brand-900"><%= @lead.company_type.presence || "Not provided" %></p>
        </div>

        <div>
          <p class="text-sm font-bold text-slate-500">Revenue Range</p>
          <p class="mt-1 text-brand-900"><%= @lead.revenue_range.presence || "Not provided" %></p>
        </div>

        <div>
          <p class="text-sm font-bold text-slate-500">EBITDA / ARR Range</p>
          <p class="mt-1 text-brand-900"><%= @lead.ebitda_range.presence || "Not provided" %></p>
        </div>

        <div>
          <p class="text-sm font-bold text-slate-500">Status</p>
          <%= form_with model: [:admin, @lead], method: :patch, class: "mt-1 flex items-center gap-2" do |f| %>
            <%= f.select :status,
              Lead.statuses.keys.map { |s| [s.humanize, s] },
              {},
              class: "rounded-lg border border-slate-300 px-3 py-1.5 text-sm text-brand-900" %>
            <%= f.submit "Update", class: "rounded-lg bg-brand-900 px-3 py-1.5 text-sm font-bold text-white hover:bg-black" %>
          <% end %>
        </div>

        <div>
          <p class="text-sm font-bold text-slate-500">Submitted</p>
          <p class="mt-1 text-brand-900"><%= @lead.created_at.strftime("%d %b %Y, %I:%M %p") %></p>
        </div>
      </div>

      <% if @lead.message.present? %>
        <div class="mt-8 rounded-2xl bg-slate-50 p-6">
          <p class="text-sm font-bold text-slate-500">Message</p>
          <p class="mt-2 text-slate-700"><%= @lead.message %></p>
        </div>
      <% end %>
    </div>

    <div class="mt-6 rounded-3xl border border-slate-200 bg-white p-8 shadow-soft">
      <h2 class="text-xl font-extrabold text-brand-900">Tool activity</h2>
      <p class="mt-1 text-sm text-slate-500">What this lead generated before reaching out.</p>

      <% runs = @lead.tool_runs.order(:created_at) %>
      <% if runs.any? %>
        <div class="mt-6 space-y-4">
          <% runs.each do |run| %>
            <% r = run.result || {} %>
            <% a = run.analysis || {} %>
            <div class="rounded-2xl border border-slate-200 bg-slate-50 p-5">
              <div class="flex items-center justify-between gap-4">
                <p class="font-bold text-brand-900"><%= run.tool_type.humanize %></p>
                <p class="text-xs text-slate-500"><%= run.created_at.strftime("%d %b %Y, %I:%M %p") %></p>
              </div>

              <p class="mt-1 text-sm text-slate-600">
                <%= run.website.presence || "—" %>
                <% if (name = r["industry_name"] || a["industry_name"]).present? %>· <%= name %><% end %>
              </p>

              <% case run.tool_type %>
              <% when "valuation" %>
                <p class="mt-3 text-2xl font-extrabold text-brand-900">
                  <%= number_to_currency(r["low"].to_i, precision: 0) %> – <%= number_to_currency(r["high"].to_i, precision: 0) %>
                </p>
                <p class="text-xs text-slate-500">
                  <%= r["size_band"] %> · <%= r["implied_earnings_multiple"] %>× earnings / <%= r["implied_revenue_multiple"] %>× revenue
                </p>
              <% when "market_comps" %>
                <p class="mt-3 text-sm text-slate-700">
                  <%= r["listings_count"] %> comps · median <%= r["median_price_revenue"] %>× revenue / <%= r["median_price_cash_flow"] %>× cash flow
                </p>
              <% when "buyer_map" %>
                <p class="mt-3 text-sm text-slate-700">
                  <%= r["buyer_count"] %> active acquirers · <%= r["acquisitions_last_year"] %> acquisitions in 2025
                </p>
                <% if r["buyers"].is_a?(Array) && r["buyers"].any? %>
                  <p class="mt-1 text-xs text-slate-500"><%= r["buyers"].first(3).map { |b| b["name"] }.join(", ") %></p>
                <% end %>
              <% end %>

              <% if a["summary"].present? %>
                <p class="mt-3 text-xs italic text-slate-500"><%= a["summary"] %></p>
              <% end %>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="mt-4 text-sm text-slate-500">No tool runs linked to this lead.</p>
      <% end %>
    </div>
  </div>
</section>