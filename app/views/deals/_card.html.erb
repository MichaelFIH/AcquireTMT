<%= link_to deal_path(deal), class: "block rounded-sm border border-brand-100 bg-white p-6 shadow-soft transition hover:-translate-y-0.5" do %>
  <div class="flex items-center justify-between gap-3">
    <span class="rounded-full bg-brand-50 px-3 py-1 text-xs font-semibold text-brand-900"><%= deal.industry_name %></span>
    <% if deal.recurring %>
      <span class="text-xs font-semibold text-brand-500">Recurring revenue</span>
    <% end %>
  </div>

  <h3 class="mt-4 font-serif text-2xl font-medium text-brand-900"><%= deal.title %></h3>
  <p class="mt-1 text-sm text-slate-500"><%= deal.location %> · <%= deal.reference %></p>

  <div class="mt-5 grid grid-cols-3 gap-3 text-sm">
    <div>
      <p class="text-slate-500">Revenue</p>
      <p class="font-bold text-brand-900"><%= number_to_currency(deal.revenue, precision: 0) %></p>
    </div>
    <div>
      <p class="text-slate-500">EBITDA</p>
      <p class="font-bold text-brand-900"><%= number_to_currency(deal.ebitda, precision: 0) %></p>
    </div>
    <div>
      <p class="text-slate-500">Asking</p>
      <p class="font-bold text-brand-900"><%= number_to_currency(deal.asking_price, precision: 0) %></p>
    </div>
  </div>
<% end %>
