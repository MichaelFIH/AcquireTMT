<% content_for :title, @deal.title %>

<section class="min-h-screen bg-brand-50 py-12">
  <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
    <%= link_to "← Back to dashboard", dashboard_path, class: "text-sm font-bold text-brand-700" %>

    <% if notice.present? %>
      <p class="mt-4 rounded-sm border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm font-semibold text-emerald-700"><%= notice %></p>
    <% end %>

    <div class="mt-6 rounded-sm border border-brand-100 bg-white p-8 shadow-soft">
      <div class="flex items-center justify-between gap-3">
        <span class="rounded-full bg-brand-50 px-3 py-1 text-xs font-semibold text-brand-900"><%= @deal.industry_name %></span>
        <span class="text-xs font-semibold uppercase tracking-wide text-slate-400"><%= @deal.status_label %> · <%= @deal.reference %></span>
      </div>

      <h1 class="mt-4 font-serif text-4xl font-medium text-brand-900"><%= @deal.title %></h1>
      <p class="mt-1 text-sm text-slate-500"><%= @deal.location %></p>
      <p class="mt-4 text-base leading-7 text-slate-700"><%= @deal.teaser %></p>

      <div class="mt-8 grid gap-4 sm:grid-cols-3">
        <% [["Revenue", @deal.revenue], ["EBITDA", @deal.ebitda], ["Asking price", @deal.asking_price]].each do |label, value| %>
          <div class="rounded-sm border border-brand-100 bg-brand-50 p-5 text-center">
            <p class="text-xs text-slate-500"><%= label %></p>
            <p class="mt-2 font-serif text-2xl font-medium text-brand-900"><%= number_to_currency(value, precision: 0) %></p>
          </div>
        <% end %>
      </div>

      <% if @deal.highlights.any? %>
        <div class="mt-8">
          <h2 class="text-lg font-bold text-brand-900">Highlights</h2>
          <ul class="mt-3 space-y-2">
            <% @deal.highlights.each do |highlight| %>
              <li class="flex gap-3 text-sm text-slate-700">
                <span class="text-brand-300">✓</span><%= highlight %>
              </li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <% if @access&.unlocked? %>
        <!-- Unlocked data room with real documents -->
        <div class="mt-8 rounded-sm border border-brand-100 bg-white p-7">
          <div class="flex items-center gap-2">
            <%= lucide_icon "lock-open", class: "h-5 w-5 text-brand-500" %>
            <h3 class="font-serif text-2xl font-medium text-brand-900">Data room</h3>
          </div>
          <p class="mt-1 text-sm text-slate-600">Access granted. Download the deal materials below.</p>
          <% if @deal.deal_documents.any? %>
            <div class="mt-5 divide-y divide-brand-100 border-y border-brand-100">
              <% @deal.deal_documents.each do |doc| %>
                <div class="flex items-center justify-between gap-4 py-3">
                  <span class="flex items-center gap-3 text-sm text-slate-700">
                    <%= lucide_icon "file-text", class: "h-4 w-4 text-brand-500" %><%= doc.title %>
                  </span>
                  <%= link_to "Download", rails_blob_path(doc.file, disposition: "attachment"),
                    class: "text-sm font-semibold text-brand-500 hover:underline" %>
                </div>
              <% end %>
            </div>
          <% else %>
            <p class="mt-5 rounded-sm bg-brand-50 px-4 py-6 text-center text-sm text-slate-500">Documents are being prepared — the deal team will add them shortly.</p>
          <% end %>
          <p class="mt-4 text-xs text-slate-400">Confidential. NDA signed <%= @access.nda_signed_at.strftime("%d %b %Y") %>.</p>
        </div>
      <% elsif @access&.approved? %>
        <!-- Approved, awaiting NDA signature -->
        <div class="mt-8 rounded-sm border border-brand-100 bg-white p-7">
          <div class="flex items-center gap-2">
            <%= lucide_icon "file-signature", class: "h-5 w-5 text-brand-500" %>
            <h3 class="font-serif text-2xl font-medium text-brand-900">Sign the NDA to open the data room</h3>
          </div>
          <p class="mt-3 text-sm leading-6 text-slate-600">
            Your access is approved. The information in this data room is confidential. By signing, you agree to keep
            all deal materials confidential, use them solely to evaluate a potential acquisition, and not contact the
            company or its employees directly except through AcquireTMT.
          </p>
          <%= form_with url: sign_nda_deal_path(@deal), method: :post, class: "mt-5", data: { controller: "nda" } do %>
            <label class="flex items-start gap-3 text-sm text-slate-700">
              <input type="checkbox" required data-action="nda#toggle" data-nda-target="agree" class="mt-1">
              I have read and agree to the non-disclosure agreement.
            </label>
            <button type="submit" data-nda-target="submit" disabled
              class="mt-5 cursor-pointer rounded-sm bg-brand-900 px-6 py-3 text-sm font-bold text-white transition hover:bg-brand-500 disabled:cursor-not-allowed disabled:opacity-40">
              Sign NDA & open data room
            </button>
          <% end %>
        </div>
      <% elsif @access&.status == "requested" %>
        <div class="mt-8 rounded-sm border border-brand-100 bg-brand-50 p-7 text-center">
          <%= lucide_icon "clock", class: "mx-auto h-6 w-6 text-brand-500" %>
          <p class="mt-3 font-semibold text-brand-900">Access requested</p>
          <p class="mt-1 text-sm text-slate-600">Our team is reviewing your request and will unlock the data room shortly.</p>
        </div>
      <% elsif @access&.status == "declined" %>
        <div class="mt-8 rounded-sm border border-brand-100 bg-brand-50 p-7 text-center text-sm text-slate-600">
          Access to this deal isn't available for your profile right now.
        </div>
      <% else %>
        <div class="mt-8 rounded-sm bg-brand-900 p-7 text-white">
          <h3 class="font-serif text-2xl font-medium">Want the full picture?</h3>
          <p class="mt-2 text-sm leading-6 text-white/70">
            Request access to the data room — full financials, the banker-authored CIM, and a call with the deal team.
          </p>
          <%= button_to "Request access", request_access_deal_path(@deal), method: :post,
            class: "mt-5 cursor-pointer rounded-sm bg-brand-300 px-6 py-3 text-sm font-bold text-brand-900 transition hover:bg-white" %>
        </div>
      <% end %>
    </div>
  </div>
</section>
