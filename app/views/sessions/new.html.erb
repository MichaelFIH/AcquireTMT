<% content_for :title, "Sign in" %>

<section class="flex min-h-screen items-center justify-center bg-brand-50 px-4 py-16">
  <div class="w-full max-w-md">
    <div class="text-center">
      <%= link_to root_path, class: "font-serif text-3xl font-semibold text-brand-900" do %>
        Acquire<span class="text-brand-300">TMT</span>
      <% end %>
      <h1 class="mt-6 font-serif text-3xl font-medium text-brand-900">Welcome back</h1>
      <p class="mt-2 text-sm text-slate-600">Sign in to your dashboard.</p>
    </div>

    <div class="mt-8 rounded-sm border border-brand-100 bg-white p-8 shadow-soft">
      <% if alert = flash[:alert] %>
        <p class="mb-5 rounded-sm border border-red-200 bg-red-50 px-4 py-3 text-sm font-semibold text-red-700"><%= alert %></p>
      <% end %>
      <% if notice = flash[:notice] %>
        <p class="mb-5 rounded-sm border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm font-semibold text-emerald-700"><%= notice %></p>
      <% end %>

      <%= render "shared/google_button" %>
      <%= form_with url: session_url do |form| %>
        <div class="space-y-4">
          <div>
            <%= form.label :email_address, "Email", class: "block text-sm font-semibold text-brand-900" %>
            <%= form.email_field :email_address, required: true, autofocus: true, autocomplete: "username",
              value: params[:email_address],
              class: "mt-1 w-full rounded-sm border border-brand-100 px-4 py-2.5 text-sm text-brand-900 focus:border-brand-300 focus:outline-none focus:ring-1 focus:ring-brand-300" %>
          </div>
          <div>
            <%= form.label :password, class: "block text-sm font-semibold text-brand-900" %>
            <%= form.password_field :password, required: true, autocomplete: "current-password", maxlength: 72,
              class: "mt-1 w-full rounded-sm border border-brand-100 px-4 py-2.5 text-sm text-brand-900 focus:border-brand-300 focus:outline-none focus:ring-1 focus:ring-brand-300" %>
          </div>
        </div>

        <%= form.submit "Sign in",
          class: "mt-6 w-full cursor-pointer rounded-sm bg-brand-300 px-5 py-3 text-sm font-bold text-brand-900 transition hover:bg-brand-500 hover:text-white" %>
      <% end %>

      <div class="mt-5 flex items-center justify-between text-sm">
        <%= link_to "Forgot password?", new_password_path, class: "text-slate-500 hover:text-brand-500" %>
        <%= link_to "Create an account", sign_up_path, class: "font-semibold text-brand-500 hover:underline" %>
      </div>
    </div>
  </div>
</section>
