<% content_for :title, "Investment Banking for #{@industry[:name]} — AcquireTMT" %>
<% ctrl = Public::IndustriesController %>

<!-- HERO -->
<section class="relative overflow-hidden bg-brand-900 text-white">
  <div class="absolute inset-0 bg-gradient-to-br from-brand-900 via-brand-900 to-brand-500/40"></div>
  <div class="relative mx-auto max-w-7xl px-4 py-24 sm:px-6 sm:py-32 lg:px-8">
    <p class="text-sm font-semibold uppercase tracking-[0.2em] text-brand-300">AcquireTMT · <%= @industry[:name] %></p>
    <h1 class="mt-4 max-w-3xl font-serif text-5xl font-medium leading-tight sm:text-6xl">
      Investment Banking for <span class="text-brand-300"><%= @industry[:name] %></span>
    </h1>
    <p class="mt-5 max-w-xl text-lg leading-8 text-white/70">
      Pairing deep <%= @industry[:name] %> expertise with proven M&A execution.
    </p>
    <div class="mt-8 flex flex-wrap gap-3">
      <%= link_to "Find Buyers", tools_find_buyers_path,
        class: "rounded-sm bg-brand-300 px-6 py-3 text-sm font-bold text-brand-900 transition hover:bg-white" %>
      <%= link_to "Meet an Advisor", contact_path,
        class: "rounded-sm border border-white/20 px-6 py-3 text-sm font-bold text-white transition hover:bg-white/10" %>
    </div>
  </div>
</section>

<!-- NETWORK STRIP -->
<% if @network_buyers.any? %>
  <section class="border-b border-brand-100 bg-brand-50 py-10">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <p class="text-center text-xs font-semibold uppercase tracking-[0.2em] text-slate-400">Select buyers in our network</p>
      <div class="mt-6 flex flex-wrap items-center justify-center gap-x-10 gap-y-3">
        <% @network_buyers.each do |buyer| %>
          <span class="font-serif text-lg font-medium text-slate-500"><%= buyer.name %></span>
        <% end %>
      </div>
    </div>
  </section>
<% end %>

<!-- SELLING SHOULD BE EASY -->
<section class="bg-white py-20 sm:py-24">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl text-center">
      <h2 class="font-serif text-4xl font-medium text-brand-900 sm:text-5xl">Selling your business should be easy</h2>
      <p class="mt-5 text-lg leading-8 text-slate-600"><%= @industry[:intro] %></p>
    </div>
    <div class="mt-12 grid gap-4 sm:grid-cols-2">
      <% @industry[:value_drivers].each do |driver| %>
        <div class="flex items-start gap-3 rounded-sm border border-brand-100 bg-brand-50 p-5">
          <%= lucide_icon "check", class: "mt-0.5 h-5 w-5 shrink-0 text-brand-300" %>
          <span class="text-sm font-semibold text-brand-900"><%= driver %></span>
        </div>
      <% end %>
    </div>
  </div>
</section>

<!-- DEDICATED TEAM -->
<section class="bg-brand-50 py-20 sm:py-24">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <h2 class="text-center font-serif text-4xl font-medium text-brand-900">Your dedicated <%= @industry[:name] %> M&A team</h2>
    <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      <% ctrl::TEAM.each do |member| %>
        <div class="rounded-sm border border-brand-100 bg-white p-6 text-center shadow-soft">
          <span class="mx-auto flex h-16 w-16 items-center justify-center rounded-full bg-brand-900 font-serif text-xl font-medium text-white">
            <%= member[:name].split.map { |w| w[0] }.first(2).join %>
          </span>
          <p class="mt-4 font-bold text-brand-900"><%= member[:name] %></p>
          <p class="mt-1 text-sm text-slate-500"><%= member[:title] %></p>
        </div>
      <% end %>
    </div>
  </div>
</section>

<!-- SEE WHO'S BUYING -->
<section class="bg-white py-20 sm:py-24">
  <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="font-serif text-4xl font-medium text-brand-900">Your sector is selling — see who's buying</h2>
      <p class="mt-4 text-base leading-7 text-slate-600">
        <%= @industry[:name] %> M&A activity is accelerating. Preview the active acquirers for a business like yours.
      </p>
    </div>

    <div class="mt-10 rounded-sm border border-brand-100 bg-brand-50 p-6 shadow-soft sm:p-8">
      <p class="text-sm font-semibold text-brand-900">Preview <%= @industry[:name] %> buyers</p>
      <%= form_with url: tools_find_buyers_path, method: :get, class: "mt-3 flex flex-col gap-3 sm:flex-row" do %>
        <%= text_field_tag :website, nil, placeholder: "Company website URL",
          class: "flex-1 rounded-sm border border-brand-100 bg-white px-5 py-3 text-sm text-brand-900 placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-brand-300" %>
        <%= submit_tag "Find Buyers",
          class: "cursor-pointer rounded-sm bg-brand-900 px-8 py-3 text-sm font-bold text-white transition hover:bg-brand-500" %>
      <% end %>

      <% if @network_buyers.any? %>
        <div class="mt-6 grid gap-3 sm:grid-cols-2">
          <% @network_buyers.first(4).each do |buyer| %>
            <div class="flex items-center justify-between rounded-sm border border-brand-100 bg-white px-4 py-3">
              <span class="text-sm font-semibold text-brand-900"><%= buyer.name %></span>
              <span class="text-xs font-semibold text-brand-500"><%= buyer.type_label %></span>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</section>

<!-- WHY CHOOSE -->
<section class="bg-brand-50 py-20 sm:py-24">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <h2 class="text-center font-serif text-4xl font-medium text-brand-900">Why <%= @industry[:name] %> owners choose AcquireTMT</h2>
    <div class="mt-12 grid gap-6 lg:grid-cols-3">
      <% ctrl::WHY_CHOOSE.each do |card| %>
        <div class="rounded-sm border border-brand-100 bg-white p-8 shadow-soft">
          <span class="flex h-11 w-11 items-center justify-center rounded-sm bg-brand-50 text-brand-500">
            <%= lucide_icon card[:icon], class: "h-5 w-5" %>
          </span>
          <h3 class="mt-5 font-serif text-2xl font-medium text-brand-900"><%= card[:title] %></h3>
          <p class="mt-2 text-sm leading-7 text-slate-600"><%= card[:body] %></p>
        </div>
      <% end %>
    </div>
  </div>
</section>

<!-- HIGHLIGHTS -->
<section class="bg-brand-900 py-20 text-white sm:py-24">
  <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
    <h2 class="text-center font-serif text-4xl font-medium">Highlights</h2>
    <div class="mt-10 space-y-4">
      <% ctrl::HIGHLIGHTS.each do |item| %>
        <details class="group rounded-sm border border-white/10 bg-white/5 p-6">
          <summary class="flex cursor-pointer list-none items-center justify-between gap-6">
            <span class="font-serif text-xl font-medium"><%= item[:title] %></span>
            <%= lucide_icon "plus", class: "h-5 w-5 shrink-0 text-brand-300 transition group-open:rotate-45" %>
          </summary>
          <p class="mt-4 text-sm leading-7 text-white/70"><%= item[:body] %></p>
        </details>
      <% end %>
    </div>
  </div>
</section>

<!-- UPCOMING EVENTS -->
<section class="bg-white py-20 sm:py-24">
  <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
    <h2 class="font-serif text-4xl font-medium text-brand-900">Upcoming events</h2>
    <div class="mt-10 divide-y divide-brand-100 border-y border-brand-100">
      <% ctrl::EVENTS.each do |event| %>
        <div class="flex flex-col gap-4 py-6 sm:flex-row sm:items-center sm:justify-between">
          <div>
            <p class="font-serif text-2xl font-medium text-brand-900"><%= event[:name] %></p>
            <p class="mt-1 text-sm text-slate-500"><%= event[:type] %> · <%= event[:location] %> · <%= event[:date] %></p>
          </div>
          <%= link_to "Schedule a chat", contact_path,
            class: "w-fit rounded-sm border border-brand-100 px-5 py-2.5 text-sm font-bold text-brand-900 transition hover:bg-brand-50" %>
        </div>
      <% end %>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="bg-brand-50 py-20">
  <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
    <div class="rounded-sm bg-brand-900 p-8 text-white shadow-soft sm:p-12">
      <h2 class="font-serif text-3xl font-medium sm:text-4xl">Curious about your potential buyers?</h2>
      <p class="mt-3 max-w-xl text-sm leading-7 text-white/70">
        Get a free, personalized list of active buyers for your <%= @industry[:name] %> business.
      </p>
      <%= form_with url: tools_find_buyers_path, method: :get, class: "mt-6 flex flex-col gap-3 sm:flex-row" do %>
        <%= text_field_tag :website, nil, placeholder: "Company website URL",
          class: "flex-1 rounded-sm border border-white/10 bg-white px-5 py-4 text-sm text-brand-900 placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-brand-300" %>
        <%= submit_tag "Find Buyers",
          class: "cursor-pointer rounded-sm bg-brand-300 px-8 py-4 text-sm font-bold text-brand-900 transition hover:bg-white" %>
      <% end %>
    </div>
  </div>
</section>
