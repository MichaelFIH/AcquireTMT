<% content_for :title, "Investment Banking for #{@industry[:name]} — AcquireTMT" %>
<% ctrl = Public::IndustriesController %>

<!-- HERO -->
<section class="relative overflow-hidden bg-brand-900 text-white">
  <%# A per-industry photo can be set as @industry[:hero_image]; falls back to a gradient. %>
  <% if @industry[:hero_image].present? %>
    <%= image_tag @industry[:hero_image], class: "absolute inset-0 h-full w-full object-cover", alt: @industry[:name] %>
    <div class="absolute inset-0 bg-gradient-to-t from-brand-900 via-brand-900/70 to-brand-900/40"></div>
  <% else %>
    <div class="absolute inset-0 bg-gradient-to-br from-brand-900 via-brand-900 to-brand-500/40"></div>
  <% end %>
  <div class="relative mx-auto max-w-7xl px-4 py-28 sm:px-6 sm:py-36 lg:px-8">
    <h1 class="max-w-3xl font-serif text-5xl font-medium leading-tight sm:text-6xl">
      <span class="text-white">Investment Banking for</span><br>
      <span class="text-brand-300"><%= @industry[:name] %></span>
    </h1>
    <p class="mt-5 max-w-xl text-lg leading-8 text-white/70">Pairing industry expertise with proven M&A execution.</p>
    <div class="mt-8 flex flex-wrap gap-3">
      <%= link_to "Find Buyers", tools_find_buyers_path,
        class: "rounded-sm bg-white px-6 py-3 text-sm font-bold text-brand-900 transition hover:bg-brand-300" %>
      <%= link_to "Meet an Advisor", contact_path,
        class: "rounded-sm border border-white/20 px-6 py-3 text-sm font-bold text-white transition hover:bg-white/10" %>
    </div>
  </div>
</section>

<!-- NETWORK STRIP (marquee) -->
<% if @network_logos.any? %>
  <section class="border-b border-brand-100 bg-white py-10">
    <div class="mx-auto flex max-w-7xl flex-col gap-6 px-4 sm:px-6 md:flex-row md:items-center md:gap-10 lg:px-8">
      <p class="shrink-0 font-serif text-xl font-medium text-slate-500 md:w-48">Select buyers in our network</p>
      <div class="marquee group min-w-0 flex-1">
        <div class="marquee-track">
          <% 2.times do %>
            <div class="flex shrink-0 items-center gap-x-14 pr-14">
              <% @network_logos.each do |buyer| %>
                <span class="flex items-center gap-3 whitespace-nowrap text-slate-500 transition duration-500 group-hover:text-brand-900">
                  <%= image_tag buyer.logo_url, class: "h-10 w-10 rounded-sm object-contain grayscale transition duration-500 group-hover:grayscale-0", alt: buyer.name, loading: "lazy" %>
                  <span class="font-serif text-2xl font-medium"><%= buyer.name %></span>
                </span>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </section>
<% end %>

<!-- SELLING SHOULD BE EASY (+ dedicated team) -->
<section class="bg-brand-50 py-20 sm:py-24">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid items-center gap-12 lg:grid-cols-2">
      <!-- Team card -->
      <div class="rounded-sm bg-white p-6 shadow-soft sm:p-8">
        <p class="text-center font-bold text-brand-900">Your dedicated <%= @industry[:name] %> M&A advisors</p>
        <div class="mt-6 grid grid-cols-2 gap-6">
          <% ctrl::TEAM.each do |member| %>
            <div class="flex flex-col items-center gap-3 text-center">
              <span class="flex h-20 w-20 items-center justify-center rounded-full bg-brand-900 font-serif text-2xl font-medium text-white">
                <%= member[:name].split.map { |w| w[0] }.first(2).join %>
              </span>
              <div>
                <p class="font-serif text-lg font-medium text-brand-900"><%= member[:name] %></p>
                <p class="text-sm text-slate-500"><%= member[:title] %></p>
              </div>
            </div>
          <% end %>
        </div>
      </div>

      <!-- Copy -->
      <div>
        <h2 class="font-serif text-4xl font-medium leading-tight text-brand-900 sm:text-5xl">
          Selling your business<br><span class="text-brand-300">should be easy</span>
        </h2>
        <p class="mt-5 text-lg leading-8 text-slate-600"><%= @industry[:intro] %></p>
        <div class="mt-6 grid gap-3 sm:grid-cols-2">
          <% @industry[:value_drivers].each do |driver| %>
            <div class="flex items-start gap-2 text-sm font-semibold text-brand-900">
              <%= lucide_icon "check", class: "mt-0.5 h-4 w-4 shrink-0 text-brand-300" %><%= driver %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- SEE WHO'S BUYING -->
<section class="bg-white py-20 sm:py-24">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl text-center">
      <h2 class="font-serif text-4xl font-medium text-brand-900 sm:text-5xl">Your neighbors are selling — see who's buying</h2>
      <p class="mt-4 text-lg leading-8 text-slate-600">
        <%= @industry[:name] %> M&A activity is accelerating across the US — see who's looking for their next acquisition.
      </p>
    </div>

    <div class="mt-12 grid gap-6 lg:grid-cols-[1fr_400px]" data-controller="usmap">
      <!-- Interactive buyer-activity map -->
      <div class="overflow-hidden rounded-sm border border-brand-100 bg-brand-50 p-4">
        <svg viewBox="192 9 1028 746" preserveAspectRatio="xMidYMid meet" class="h-full w-full" role="img" aria-label="US buyer activity map">
          <%= render "shared/us_map_paths" %>
          <% @network_buyers.each_with_index do |buyer, i| %>
            <g data-usmap-target="group" data-buyer="<%= i %>" style="transition:opacity .2s">
              <% ctrl.cities_for(buyer.name).each do |x, y| %>
                <circle cx="<%= x %>" cy="<%= y %>" r="8" fill="#C8A24A" fill-opacity="0.75" stroke="#FFFFFF" stroke-width="1.5" />
              <% end %>
            </g>
          <% end %>
        </svg>
      </div>

      <!-- Right column: buyer list <-> detail -->
      <div>
        <!-- LIST -->
        <div data-usmap-target="list" class="flex flex-col rounded-sm border border-brand-100 bg-brand-50 shadow-soft">
          <div class="p-6">
            <p class="font-bold text-brand-900">Active buyers</p>
            <p class="mt-1 text-sm text-slate-500">Hover to see locations · click for details</p>
          </div>
          <div class="divide-y divide-brand-100 border-t border-brand-100">
            <% @network_buyers.each_with_index do |buyer, i| %>
              <button type="button" data-buyer="<%= i %>"
                data-action="mouseenter->usmap#hover mouseleave->usmap#unhover click->usmap#select"
                class="flex w-full items-center justify-between gap-3 px-6 py-4 text-left transition hover:bg-white">
                <span class="text-sm font-semibold text-brand-900"><%= buyer.name %></span>
                <span class="flex items-center gap-3">
                  <span class="text-sm text-slate-500"><%= buyer.acquisitions_count.positive? ? "#{buyer.acquisitions_count} deals" : buyer.type_label %></span>
                  <%= lucide_icon "chevron-right", class: "h-4 w-4 text-slate-400" %>
                </span>
              </button>
            <% end %>
          </div>
          <div class="border-t border-brand-100 p-6">
            <p class="text-sm font-semibold text-brand-900">Preview <%= @industry[:name] %> buyers</p>
            <%= form_with url: tools_find_buyers_path, method: :get, class: "mt-3" do %>
              <%= text_field_tag :website, nil, placeholder: "Company website URL",
                class: "w-full rounded-sm border border-brand-100 bg-white px-4 py-3 text-sm text-brand-900 placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-brand-300" %>
              <%= submit_tag "Find Buyers",
                class: "mt-3 w-full cursor-pointer rounded-sm bg-brand-900 px-6 py-3 text-sm font-bold text-white transition hover:bg-brand-500" %>
            <% end %>
          </div>
        </div>

        <!-- DETAIL panels -->
        <% @network_buyers.each_with_index do |buyer, i| %>
          <div data-usmap-target="detail" data-buyer="<%= i %>" class="hidden rounded-sm border border-brand-100 bg-brand-50 p-6 shadow-soft">
            <button type="button" data-action="usmap#back" class="flex items-center gap-2 text-sm font-bold text-brand-700 hover:underline">
              <%= lucide_icon "arrow-left", class: "h-4 w-4" %> Back
            </button>
            <div class="mt-4 flex items-start justify-between gap-4">
              <div>
                <h3 class="font-serif text-2xl font-medium text-brand-900"><%= buyer.name %></h3>
                <p class="mt-1 text-xs font-semibold uppercase tracking-wide text-brand-500"><%= buyer.type_label %></p>
              </div>
              <% if buyer.logo_url.present? %>
                <img src="<%= buyer.logo_url %>" alt="<%= buyer.name %> logo" loading="lazy"
                  onerror="this.style.display='none'"
                  class="h-10 w-10 shrink-0 rounded-sm border border-brand-100 bg-white object-contain p-1.5">
              <% end %>
            </div>

            <% if buyer.backed_by.present? %>
              <div class="mt-5 border-t border-brand-100 pt-5">
                <p class="flex items-center gap-2 text-sm font-bold text-brand-900"><%= lucide_icon "circle-dollar-sign", class: "h-4 w-4 text-brand-500" %> Backed by</p>
                <p class="mt-1 text-sm text-slate-600"><%= buyer.backed_by %></p>
              </div>
            <% end %>

            <% if buyer.acquisitions_count.positive? %>
              <div class="mt-5 border-t border-brand-100 pt-5">
                <p class="flex items-center gap-2 text-sm font-bold text-brand-900"><%= lucide_icon "history", class: "h-4 w-4 text-brand-500" %> Recent activity</p>
                <p class="mt-1 text-sm text-slate-600"><%= buyer.acquisitions_count %> acquisitions in 2025</p>
              </div>
            <% end %>

            <% if buyer.website_url.present? %>
              <div class="mt-5 border-t border-brand-100 pt-5">
                <p class="flex items-center gap-2 text-sm font-bold text-brand-900"><%= lucide_icon "globe", class: "h-4 w-4 text-brand-500" %> Website</p>
                <%= link_to buyer.website_url, target: "_blank", rel: "noopener",
                  class: "mt-1 inline-flex items-center gap-1 text-sm font-semibold text-brand-500 hover:underline" do %>
                  <%= buyer.domain %><%= lucide_icon "external-link", class: "h-3.5 w-3.5" %>
                <% end %>
              </div>
            <% end %>

            <div class="mt-5 border-t border-brand-100 pt-5">
              <p class="text-sm font-bold text-brand-900">What they're looking for</p>
              <p class="mt-1 text-sm leading-6 text-slate-600"><%= buyer.thesis %></p>
            </div>

            <%= link_to "See if they're interested in your business", tools_find_buyers_path,
              class: "mt-6 block rounded-sm bg-brand-900 px-5 py-3 text-center text-sm font-bold text-white transition hover:bg-brand-500" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</section>

<!-- WHY CHOOSE -->
<section class="bg-brand-50 py-20 sm:py-24">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <h2 class="text-center font-serif text-4xl font-medium text-brand-900">Why <%= @industry[:name] %> owners choose AcquireTMT</h2>
    <div class="mt-12 grid gap-6 lg:grid-cols-3">
      <% ctrl::WHY_CHOOSE.each do |card| %>
        <div class="rounded-sm border border-brand-100 bg-white p-8 shadow-soft">
          <span class="flex h-11 w-11 items-center justify-center rounded-sm bg-brand-50 text-brand-500">
            <%= lucide_icon card[:icon], class: "h-5 w-5" %>
          </span>
          <h3 class="mt-5 font-serif text-2xl font-medium text-brand-900"><%= card[:title] %></h3>
          <p class="mt-2 text-sm leading-7 text-slate-600"><%= card[:body] %></p>
        </div>
      <% end %>
    </div>
  </div>
</section>

<!-- HIGHLIGHTS -->
<section class="bg-brand-900 py-20 text-white sm:py-24">
  <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
    <h2 class="text-center font-serif text-4xl font-medium">Highlights</h2>
    <div class="mt-10 space-y-4">
      <% ctrl::HIGHLIGHTS.each do |item| %>
        <details class="group rounded-sm border border-white/10 bg-white/5 p-6">
          <summary class="flex cursor-pointer list-none items-center justify-between gap-6">
            <span class="font-serif text-xl font-medium"><%= item[:title] %></span>
            <%= lucide_icon "plus", class: "h-5 w-5 shrink-0 text-brand-300 transition group-open:rotate-45" %>
          </summary>
          <p class="mt-4 text-sm leading-7 text-white/70"><%= item[:body] %></p>
        </details>
      <% end %>
    </div>
  </div>
</section>

<!-- UPCOMING EVENTS -->
<section class="bg-white py-20 sm:py-24">
  <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
    <h2 class="font-serif text-4xl font-medium text-brand-900">Upcoming events</h2>
    <div class="mt-10 divide-y divide-brand-100 border-y border-brand-100">
      <% ctrl::EVENTS.each do |event| %>
        <div class="flex flex-col gap-4 py-6 sm:flex-row sm:items-center sm:justify-between">
          <div>
            <p class="font-serif text-2xl font-medium text-brand-900"><%= event[:name] %></p>
            <p class="mt-1 text-sm text-slate-500"><%= event[:type] %> · <%= event[:location] %> · <%= event[:date] %></p>
          </div>
          <%= link_to "Schedule a chat", contact_path,
            class: "w-fit rounded-sm border border-brand-100 px-5 py-2.5 text-sm font-bold text-brand-900 transition hover:bg-brand-50" %>
        </div>
      <% end %>
    </div>
  </div>
</section>

<!-- CTA (text left, image right) -->
<section class="bg-white py-20 sm:py-24">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid items-center gap-10 rounded-sm bg-brand-50 p-8 sm:p-12 lg:grid-cols-2">
      <div>
        <h2 class="font-serif text-4xl font-medium leading-tight text-brand-900 sm:text-5xl">
          Curious about your<br><span class="text-slate-400">potential buyers?</span>
        </h2>
        <p class="mt-5 text-lg leading-8 text-slate-600">
          Try our <span class="font-bold text-brand-900">AI Buyer Match tool</span> to receive a personalized list of active buyers in your industry.
        </p>
        <%= form_with url: tools_find_buyers_path, method: :get, class: "mt-7 flex max-w-md gap-2 rounded-sm bg-white p-2 shadow-soft" do %>
          <%= text_field_tag :website, nil, placeholder: "Company website URL",
            class: "min-w-0 flex-1 rounded-sm px-4 py-3 text-sm text-brand-900 placeholder:text-slate-400 focus:outline-none" %>
          <%= submit_tag "Find Buyers",
            class: "shrink-0 cursor-pointer rounded-sm bg-brand-900 px-6 py-3 text-sm font-bold text-white transition hover:bg-brand-500" %>
        <% end %>
      </div>
      <div class="overflow-hidden rounded-sm">
        <%= image_tag "cta-owner.jpg", class: "aspect-[4/3] w-full object-cover", alt: "Business owner exploring their options", loading: "lazy" %>
      </div>
    </div>
  </div>
</section>
