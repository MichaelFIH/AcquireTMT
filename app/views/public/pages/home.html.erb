<section class="bg-brand-50">
  <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8 lg:py-24">
    <div class="mx-auto max-w-4xl text-center animate-fade-up">
      <div class="mb-5 inline-flex items-center gap-2 rounded-full border border-slate-200 bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-soft">
        <%= lucide_icon "sparkles", class: "h-4 w-4 text-brand-500" %>
        AI-assisted M&A advisory for TMT companies
      </div>

      <h1 class="text-4xl font-extrabold tracking-tight text-brand-900 sm:text-5xl lg:text-6xl">
        The M&A advisory firm for technology, media, and telecom business owners.
      </h1>

      <p class="mx-auto mt-6 max-w-2xl text-lg leading-8 text-slate-600">
        Confidential exits for SaaS, telecom, media, digital infrastructure, and tech-enabled services companies.
      </p>

      <div class="mt-8 flex flex-col items-center justify-center gap-3 sm:flex-row">
        <%= link_to tools_find_buyers_path,
          class: "inline-flex w-full items-center justify-center gap-2 rounded-full bg-brand-900 px-6 py-3 text-sm font-bold text-white hover:bg-slate-800 sm:w-auto" do %>
          <%= lucide_icon "search", class: "h-4 w-4" %>
          Find Buyers for My Business
        <% end %>

        <%= link_to tools_valuation_path,
          class: "inline-flex w-full items-center justify-center gap-2 rounded-full border border-slate-300 bg-white px-6 py-3 text-sm font-bold text-brand-900 hover:bg-slate-50 sm:w-auto" do %>
          <%= lucide_icon "chart-column", class: "h-4 w-4" %>
          Get Valuation Snapshot
        <% end %>
      </div>
    </div>
  </div>
</section>
<section class="border-y border-slate-200 bg-white">
  <div class="mx-auto grid max-w-7xl grid-cols-1 gap-6 px-4 py-8 sm:grid-cols-3 sm:px-6 lg:px-8">
    <div class="flex items-start gap-3 rounded-2xl p-4 hover-lift">
      <%= lucide_icon "target", class: "mt-1 h-5 w-5 text-brand-500" %>
      <div>
        <p class="text-2xl font-extrabold text-brand-900">TMT-focused</p>
        <p class="mt-1 text-sm text-slate-500">Built for technology, media, telecom, and digital infrastructure exits.</p>
      </div>
    </div>

    <div class="flex items-start gap-3 rounded-2xl p-4 hover-lift animate-fade-up animate-delay-100">
      <%= lucide_icon "network", class: "mt-1 h-5 w-5 text-brand-500" %>
      <div>
        <p class="text-2xl font-extrabold text-brand-900">BuyerMap</p>
        <p class="mt-1 text-sm text-slate-500">AI-assisted buyer discovery across strategic and financial acquirers.</p>
      </div>
    </div>

    <div class="flex items-start gap-3 rounded-2xl p-4 hover-lift animate-fade-up animate-delay-200">
      <%= lucide_icon "shield-check", class: "mt-1 h-5 w-5 text-brand-500" %>
      <div>
        <p class="text-2xl font-extrabold text-brand-900">Confidential</p>
        <p class="mt-1 text-sm text-slate-500">Private outreach workflows designed for serious sellers and buyers.</p>
      </div>
    </div>
  </div>
</section>
<section class="bg-slate-50 py-20">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="max-w-3xl animate-fade-up">
      <span class="inline-flex items-center gap-2 rounded-full bg-white px-4 py-2 text-sm font-semibold text-brand-700 shadow-soft">
        <%= lucide_icon "arrow-right-left", class: "h-4 w-4" %>
        A better way to sell a TMT business
      </span>

      <h2 class="mt-5 text-3xl font-extrabold tracking-tight text-brand-900 sm:text-4xl">
        The traditional process is slow. We make it clearer.
      </h2>

      <p class="mt-4 max-w-2xl text-lg text-slate-600">
        Selling a technology, telecom, or media business can be fragmented and time consuming. AcquireTMT combines sector focus, buyer intelligence and structured outreach into one process.
      </p>
    </div>

    <div class="mt-12 grid gap-8 lg:grid-cols-2">
      <!-- Traditional -->
      <div class="hover-lift rounded-3xl border border-slate-200 bg-white p-8 shadow-soft">
        <div class="mb-5 inline-flex rounded-2xl bg-red-50 p-3 text-red-500">
          <%= lucide_icon "triangle-alert", class: "h-6 w-6" %>
        </div>

        <h3 class="text-xl font-bold text-slate-900">
          Traditional M&A Process
        </h3>

        <ul class="mt-6 space-y-4">
          <% [
            "Limited buyer outreach",
            "Slow deal timelines",
            "Unclear valuation expectations",
            "Fragmented advisory process",
            "Less visibility into buyer fit"
          ].each do |item| %>

            <li class="flex items-start gap-3 text-slate-600">
              <%= lucide_icon "x", class: "mt-1 h-4 w-4 text-red-500" %>
              <span><%= item %></span>
            </li>
          <% end %>
        </ul>
      </div>

      <!-- AcquireTMT -->
      <div class="hover-lift rounded-3xl bg-brand-900 p-8 text-white shadow-soft">
        <div class="mb-5 inline-flex rounded-2xl bg-white/10 p-3">
          <%= lucide_icon "sparkles", class: "h-6 w-6 text-white" %>
        </div>

        <h3 class="text-xl font-bold">
          The AcquireTMT Way
        </h3>

        <ul class="mt-6 space-y-4">
          <% [
            "AI-assisted buyer discovery",
            "Sector-specific TMT focus",
            "Confidential outreach process",
            "Valuation and market insights",
            "Qualified buyer universe"
          ].each do |item| %>

            <li class="flex items-start gap-3 text-slate-200">
              <%= lucide_icon "check", class: "mt-1 h-4 w-4 text-emerald-400" %>
              <span><%= item %></span>
            </li>
          <% end %>
        </ul>
      </div>
    </div>
  </div>
</section>
<section class="bg-white py-20">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="max-w-3xl animate-fade-up">
      <span class="inline-flex items-center gap-2 rounded-full bg-brand-50 px-4 py-2 text-sm font-semibold text-brand-700">
        <%= lucide_icon "workflow", class: "h-4 w-4" %>
        How it works
      </span>

      <h2 class="mt-5 text-3xl font-extrabold tracking-tight text-brand-900 sm:text-4xl">
        A structured process built for better outcomes.
      </h2>

      <p class="mt-4 max-w-2xl text-lg text-slate-600">
        From buyer discovery to diligence and offers, AcquireTMT helps technology, telecom and media business owners navigate the process with clarity.
      </p>
    </div>

    <div class="mt-14 grid gap-6 sm:grid-cols-2 xl:grid-cols-5">

      <div class="hover-lift rounded-3xl border border-slate-200 bg-white p-6 shadow-soft">
        <div class="mb-5 inline-flex rounded-2xl bg-brand-50 p-3">
          <%= lucide_icon "building-2", class: "h-6 w-6 text-brand-500" %>
        </div>

        <h3 class="text-lg font-bold text-brand-900">
          Understand Your Business
        </h3>

        <p class="mt-3 text-sm text-slate-600">
          Review business model, revenue quality, growth drivers and positioning.
        </p>
      </div>

      <div class="hover-lift rounded-3xl border border-slate-200 bg-white p-6 shadow-soft">
        <div class="mb-5 inline-flex rounded-2xl bg-brand-50 p-3">
          <%= lucide_icon "network", class: "h-6 w-6 text-brand-500" %>
        </div>

        <h3 class="text-lg font-bold text-brand-900">
          Build Buyer Universe
        </h3>

        <p class="mt-3 text-sm text-slate-600">
          Identify strategic buyers, PE-backed platforms, family offices and search funds.
        </p>
      </div>

      <div class="hover-lift rounded-3xl border border-slate-200 bg-white p-6 shadow-soft">
        <div class="mb-5 inline-flex rounded-2xl bg-brand-50 p-3">
          <%= lucide_icon "send", class: "h-6 w-6 text-brand-500" %>
        </div>

        <h3 class="text-lg font-bold text-brand-900">
          Confidential Outreach
        </h3>

        <p class="mt-3 text-sm text-slate-600">
          Run targeted buyer outreach while protecting confidentiality.
        </p>
      </div>

      <div class="hover-lift rounded-3xl border border-slate-200 bg-white p-6 shadow-soft">
        <div class="mb-5 inline-flex rounded-2xl bg-brand-50 p-3">
          <%= lucide_icon "badge-dollar-sign", class: "h-6 w-6 text-brand-500" %>
        </div>

        <h3 class="text-lg font-bold text-brand-900">
          Evaluate Offers
        </h3>

        <p class="mt-3 text-sm text-slate-600">
          Compare buyer interest, valuation expectations and deal structure.
        </p>
      </div>

      <div class="hover-lift rounded-3xl border border-slate-200 bg-white p-6 shadow-soft">
        <div class="mb-5 inline-flex rounded-2xl bg-brand-50 p-3">
          <%= lucide_icon "shield-check", class: "h-6 w-6 text-brand-500" %>
        </div>

        <h3 class="text-lg font-bold text-brand-900">
          Diligence & Close
        </h3>

        <p class="mt-3 text-sm text-slate-600">
          Coordinate diligence and move toward a successful close.
        </p>
      </div>

    </div>
  </div>
</section>
<section class="bg-slate-50 py-20">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl text-center animate-fade-up">
      <span class="inline-flex items-center gap-2 rounded-full bg-white px-4 py-2 text-sm font-semibold text-brand-700 shadow-soft">
        <%= lucide_icon "wand-sparkles", class: "h-4 w-4" %>
        Lead generation tools
      </span>

      <h2 class="mt-5 text-3xl font-extrabold tracking-tight text-brand-900 sm:text-4xl">
        Start with a free TMT exit snapshot.
      </h2>

      <p class="mt-4 text-lg text-slate-600">
        Use AcquireTMT tools to identify possible buyers, estimate valuation, and understand market interest before starting a formal sale process.
      </p>
    </div>

    <div class="mt-14 grid gap-6 lg:grid-cols-3">
      <%= link_to tools_find_buyers_path,
        class: "hover-lift group rounded-3xl border border-slate-200 bg-white p-8 shadow-soft" do %>
        <div class="mb-6 inline-flex rounded-2xl bg-brand-50 p-3">
          <%= lucide_icon "network", class: "h-7 w-7 text-brand-500" %>
        </div>

        <h3 class="text-xl font-bold text-brand-900">
          AcquireTMT BuyerMap
        </h3>

        <p class="mt-3 text-sm leading-6 text-slate-600">
          Enter your company details and receive a preliminary buyer universe across strategic acquirers, PE-backed platforms, family offices, search funds, and international buyers.
        </p>

        <div class="mt-6 flex items-center gap-2 text-sm font-bold text-brand-700">
          Find TMT Buyers
          <%= lucide_icon "arrow-right", class: "h-4 w-4 transition group-hover:translate-x-1" %>
        </div>
      <% end %>

      <%= link_to tools_valuation_path,
        class: "hover-lift group rounded-3xl border border-slate-200 bg-white p-8 shadow-soft" do %>
        <div class="mb-6 inline-flex rounded-2xl bg-brand-50 p-3">
          <%= lucide_icon "chart-column", class: "h-7 w-7 text-brand-500" %>
        </div>

        <h3 class="text-xl font-bold text-brand-900">
          TMT Valuation Snapshot
        </h3>

        <p class="mt-3 text-sm leading-6 text-slate-600">
          Estimate valuation using inputs like revenue mix, EBITDA, ARR/MRR, gross margin, churn, customer concentration, contracts, and buyer demand.
        </p>

        <div class="mt-6 flex items-center gap-2 text-sm font-bold text-brand-700">
          Get Valuation Snapshot
          <%= lucide_icon "arrow-right", class: "h-4 w-4 transition group-hover:translate-x-1" %>
        </div>
      <% end %>

      <%= link_to tools_market_comps_path,
        class: "hover-lift group rounded-3xl border border-slate-200 bg-white p-8 shadow-soft" do %>
        <div class="mb-6 inline-flex rounded-2xl bg-brand-50 p-3">
          <%= lucide_icon "chart-line", class: "h-7 w-7 text-brand-500" %>
        </div>

        <h3 class="text-xl font-bold text-brand-900">
          TMT Market Comps Report
        </h3>

        <p class="mt-3 text-sm leading-6 text-slate-600">
          Benchmark your company against sector multiples, comparable transactions, public/private comps, and current buyer demand indicators.
        </p>

        <div class="mt-6 flex items-center gap-2 text-sm font-bold text-brand-700">
          Generate Comps Report
          <%= lucide_icon "arrow-right", class: "h-4 w-4 transition group-hover:translate-x-1" %>
        </div>
      <% end %>
    </div>
  </div>
</section>
<section class="bg-white py-20">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
      <div class="max-w-3xl animate-fade-up">
        <span class="inline-flex items-center gap-2 rounded-full bg-brand-50 px-4 py-2 text-sm font-semibold text-brand-700">
          <%= lucide_icon "building-2", class: "h-4 w-4" %>
          TMT verticals
        </span>

        <h2 class="mt-5 text-3xl font-extrabold tracking-tight text-brand-900 sm:text-4xl">
          Specialized advisory for high-value TMT sectors.
        </h2>

        <p class="mt-4 text-lg text-slate-600">
          AcquireTMT focuses on technology, media, telecom, digital infrastructure, and tech-enabled services companies.
        </p>
      </div>

      <%= link_to "View all industries", industry_path("saas"),
        class: "inline-flex w-full items-center justify-center gap-2 rounded-full border border-slate-300 bg-white px-5 py-3 text-sm font-bold text-brand-900 hover:bg-slate-50 sm:w-auto" %>
    </div>

    <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      <% [
        ["SaaS", "Recurring revenue, ARR, churn, gross margin and expansion revenue.", "cloud", "saas"],
        ["MSP / IT Services", "Managed IT, cybersecurity services, cloud migration and helpdesk businesses.", "server", "msp-it-services"],
        ["Telecom & Connectivity", "Fiber, VoIP, wireless, IoT connectivity and managed telecom providers.", "radio-tower", "telecom-connectivity"],
        ["Digital Media", "Content sites, newsletters, communities, podcasts and media portfolios.", "newspaper", "digital-media"]
      ].each do |title, description, icon, slug| %>

        <%= link_to industry_path(slug),
          class: "hover-lift group rounded-3xl border border-slate-200 bg-white p-6 shadow-soft" do %>
          <div class="mb-5 inline-flex rounded-2xl bg-brand-50 p-3">
            <%= lucide_icon icon, class: "h-6 w-6 text-brand-500" %>
          </div>

          <h3 class="text-lg font-bold text-brand-900">
            <%= title %>
          </h3>

          <p class="mt-3 text-sm leading-6 text-slate-600">
            <%= description %>
          </p>

          <div class="mt-5 flex items-center gap-2 text-sm font-bold text-brand-700">
            Learn more
            <%= lucide_icon "arrow-right", class: "h-4 w-4 transition group-hover:translate-x-1" %>
          </div>
        <% end %>

      <% end %>
    </div>
  </div>
</section>
<section class="bg-slate-50 py-20">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl text-center animate-fade-up">
      <span class="inline-flex items-center gap-2 rounded-full bg-white px-4 py-2 text-sm font-semibold text-brand-700 shadow-soft">
        <%= lucide_icon "handshake", class: "h-4 w-4" %>
        Client outcomes
      </span>

      <h2 class="mt-5 text-3xl font-extrabold tracking-tight text-brand-900 sm:text-4xl">
        Built to create serious buyer conversations.
      </h2>

      <p class="mt-4 text-lg text-slate-600">
        AcquireTMT helps owners prepare, position and present their companies to qualified buyers.
      </p>
    </div>

    <div class="mt-12 grid gap-6 md:grid-cols-3">
      <% [
        ["Buyer interest", "Build targeted buyer lists across strategic acquirers, PE platforms, search funds and family offices.", "users"],
        ["Offer comparison", "Compare buyer fit, valuation expectations, structure, timing and certainty of close.", "scale"],
        ["Diligence readiness", "Prepare cleaner materials, financial context and buyer-facing information before conversations move deeper.", "file-check-2"]
      ].each do |title, description, icon| %>
        <div class="hover-lift rounded-3xl border border-slate-200 bg-white p-8 shadow-soft">
          <div class="mb-6 inline-flex rounded-2xl bg-brand-50 p-3">
            <%= lucide_icon icon, class: "h-7 w-7 text-brand-500" %>
          </div>

          <h3 class="text-xl font-bold text-brand-900"><%= title %></h3>
          <p class="mt-3 text-sm leading-6 text-slate-600"><%= description %></p>
        </div>
      <% end %>
    </div>
  </div>
</section>
<section class="bg-white py-20">
  <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
    <div class="text-center animate-fade-up">
      <span class="inline-flex items-center gap-2 rounded-full bg-brand-50 px-4 py-2 text-sm font-semibold text-brand-700">
        <%= lucide_icon "circle-help", class: "h-4 w-4" %>
        FAQ
      </span>

      <h2 class="mt-5 text-3xl font-extrabold tracking-tight text-brand-900 sm:text-4xl">
        Questions sellers usually ask first.
      </h2>
    </div>

    <div class="mt-12 space-y-4">
      <% [
        ["What kind of companies does AcquireTMT work with?", "AcquireTMT focuses on technology, media, telecom, digital infrastructure, SaaS, MSP, cloud, cybersecurity, digital media and tech-enabled services companies."],
        ["Is the process confidential?", "Yes. The process is designed around confidential buyer discovery and controlled outreach so sellers can explore interest without exposing sensitive information too early."],
        ["What does BuyerMap do?", "BuyerMap helps create a preliminary buyer universe across strategic acquirers, PE-backed platforms, family offices, search funds and international buyers."],
        ["Do the valuation tools give a formal appraisal?", "No. The valuation snapshot is an informational estimate, not a formal appraisal or legal, tax, or investment advice."],
        ["Can buyers join the network?", "Yes. Buyers can join the AcquireTMT Buyer Network to receive curated TMT acquisition opportunities and seller/advisor introductions."]
      ].each_with_index do |(question, answer), index| %>

        <details class="group rounded-2xl border border-slate-200 bg-white p-6 shadow-soft" <%= "open" if index == 0 %>>
          <summary class="flex cursor-pointer list-none items-center justify-between gap-4 text-left">
            <span class="text-base font-bold text-brand-900">
              <%= question %>
            </span>

            <span class="rounded-full bg-brand-50 p-1 text-brand-700 transition group-open:rotate-45">
              <%= lucide_icon "plus", class: "h-5 w-5" %>
            </span>
          </summary>

          <p class="mt-4 text-sm leading-6 text-slate-600">
            <%= answer %>
          </p>
        </details>

      <% end %>
    </div>
  </div>
</section>
<section class="bg-brand-900 py-20 text-white">
  <div class="mx-auto max-w-5xl px-4 text-center sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl animate-fade-up">
      <h2 class="text-3xl font-extrabold tracking-tight text-white sm:text-4xl">
        Explore buyer interest for your TMT business.
      </h2>

      <p class="mx-auto mt-4 max-w-2xl text-lg text-slate-300">
        Start with a BuyerMap or valuation snapshot and understand how your company may be positioned in the market.
      </p>

      <div class="mt-8 flex flex-col justify-center gap-3 sm:flex-row">
        <%= link_to tools_find_buyers_path,
          class: "inline-flex items-center justify-center gap-2 rounded-full bg-white px-6 py-3 text-sm font-bold text-brand-900 hover:bg-slate-100" do %>
          <%= lucide_icon "search", class: "h-4 w-4" %>
          Find Buyers for My Business
        <% end %>

        <%= link_to contact_path,
          class: "inline-flex items-center justify-center gap-2 rounded-full border border-white/20 px-6 py-3 text-sm font-bold text-white hover:bg-white/10" do %>
          <%= lucide_icon "mail", class: "h-4 w-4" %>
          Contact AcquireTMT
        <% end %>
      </div>
    </div>
  </div>
</section>