<% content_for :title, "About — AcquireTMT" %>

<!-- HERO -->
<section class="bg-brand-50 py-24 sm:py-32">
  <div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
    <h1 class="font-serif text-5xl font-medium leading-tight text-brand-900 sm:text-6xl">
      Building the future of TMT investment banking
    </h1>
    <p class="mt-5 text-lg leading-8 text-slate-600">
      An AI-native investment bank helping technology, media and telecom owners exit at premium prices.
    </p>
    <div class="mt-8 flex flex-wrap justify-center gap-3">
      <%= link_to "Contact us", contact_path,
        class: "rounded-sm bg-brand-900 px-6 py-3 text-sm font-bold text-white transition hover:bg-brand-500" %>
      <%= link_to "Join the team", careers_path,
        class: "rounded-sm border border-brand-100 bg-white px-6 py-3 text-sm font-bold text-brand-900 transition hover:bg-brand-50" %>
    </div>
  </div>
</section>

<!-- A NOTE FROM THE FOUNDERS -->
<section class="bg-white py-20 sm:py-24">
  <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
    <h2 class="font-serif text-4xl font-medium text-brand-900">A note from the founders</h2>
    <div class="mt-6 space-y-5 text-base leading-8 text-slate-600">
      <p>
        We started AcquireTMT to do something the industry hadn't: an investment bank built for the
        small and lower-middle-market TMT businesses Wall Street ignores and online marketplaces
        under-serve.
      </p>
      <p>
        The traditional playbook works well — but only for billion-dollar deals. It breaks down in
        the middle market, where founders run oversold on outdated software, making smaller M&amp;A
        transactions uneconomical for the firms built to serve them.
      </p>
      <p>
        AcquireTMT combines two advantages: purpose-built technology that maps every strategic and
        financial buyer in minutes and automates the manual analysis, plus seasoned bankers who
        focus on judgment — not data entry and bureaucracy.
      </p>
    </div>
    <div class="mt-8 flex flex-wrap items-center gap-8">
      <% [["Neil Bostick", "Founder & CEO", "team/neil.jpg"], ["Andreas Becker", "CTO", "team/andreas.jpg"]].each do |name, title, img| %>
        <div class="group flex items-center gap-4">
          <%= image_tag img, class: "h-16 w-16 rounded-full object-cover grayscale transition duration-500 group-hover:grayscale-0", alt: name %>
          <div>
            <p class="font-bold text-brand-900 transition-colors group-hover:text-brand-500"><%= name %></p>
            <p class="text-sm text-slate-500"><%= title %></p>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</section>

<!-- MEET THE TEAM -->
<section class="bg-brand-50 py-20 sm:py-24">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <h2 class="text-center font-serif text-4xl font-medium text-brand-900" data-controller="reveal">Meet the team</h2>
    <p class="mx-auto mt-3 max-w-2xl text-center text-base leading-7 text-slate-600" data-controller="reveal" data-reveal-delay-value="80">
      Seasoned operators across M&A execution, research, and client advisory.
    </p>

    <% team = [
      ["Neil Bostick", "Founder & CEO", "team/neil.jpg"],
      ["Andreas Becker", "CTO", "team/andreas.jpg"],
      ["Michael Krimsky", "M&A Execution", "team/michael.jpg"],
      ["Benjamin Sacks", "Client Advisory & Deal Operations", "team/benjamin.jpg"],
      ["Ericson Dave Reyes", "Transaction Operations", "team/ericson.jpg"],
      ["Jon Loubel De Mesa", "Buyer Research & Outreach", "team/jon.jpg"],
      ["Nikko Salamanca", "Research & Transaction Preparation", "team/nikko.jpg"],
      ["Cielo Camille Alcantara", "Operations & Client Coordination", "team/cielo.jpg"]
    ] %>
    <div class="mt-12 grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
      <% team.each_with_index do |(name, title, img), i| %>
        <div class="group text-center hover-lift" data-controller="reveal" data-reveal-delay-value="<%= (i % 4) * 90 %>">
          <div class="mx-auto h-32 w-32 overflow-hidden rounded-full shadow-soft ring-2 ring-transparent transition duration-500 group-hover:ring-brand-300">
            <%= image_tag img, class: "h-full w-full object-cover grayscale transition duration-500 group-hover:grayscale-0 group-hover:scale-105", alt: name %>
          </div>
          <p class="mt-4 font-bold text-brand-900 transition-colors group-hover:text-brand-500"><%= name %></p>
          <p class="mt-1 text-sm text-slate-500"><%= title %></p>
        </div>
      <% end %>
    </div>

    <div class="mt-14 border-t border-brand-100 pt-10">
      <p class="text-center text-sm font-semibold uppercase tracking-[0.2em] text-slate-400">Summer 2026 interns</p>
      <div class="mx-auto mt-6 flex max-w-3xl flex-wrap justify-center gap-x-8 gap-y-2">
        <% ["Evan Sun", "William Lu", "Julianna Wong", "Selina Jin", "Evelyn Zhao", "Helina Han"].each do |name| %>
          <span class="font-serif text-lg font-medium text-brand-900"><%= name %></span>
        <% end %>
      </div>
    </div>
  </div>
</section>

<!-- BACKED BY -->
<section class="bg-brand-50 py-16">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <h2 class="text-center font-serif text-3xl font-medium text-brand-900">Backed by the best</h2>
    <div class="mt-8 flex flex-wrap items-center justify-center gap-x-12 gap-y-4">
      <% ["Y Combinator", "Founders Fund", "TMT Ventures", "Centre Street Partners"].each do |name| %>
        <span class="font-serif text-xl font-medium text-slate-400"><%= name %></span>
      <% end %>
    </div>
  </div>
</section>

<!-- BUILT BY -->
<section class="bg-white py-16">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <h2 class="text-center font-serif text-3xl font-medium text-brand-900">Built by investment bankers and technologists</h2>
    <div class="mt-8 flex flex-wrap items-center justify-center gap-x-12 gap-y-4">
      <% ["Evercore", "Barclays", "Google", "Stripe", "Citadel", "Two Sigma"].each do |name| %>
        <span class="text-lg font-bold uppercase tracking-wide text-slate-400"><%= name %></span>
      <% end %>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="bg-brand-900 py-20 text-white sm:py-24">
  <div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
    <h2 class="font-serif text-4xl font-medium">Interested in building the future of TMT M&A?</h2>
    <p class="mt-3 text-base leading-7 text-white/70">We're hiring bankers and engineers to modernize dealmaking.</p>
    <%= link_to "See open roles", careers_path,
      class: "mt-7 inline-flex rounded-sm bg-brand-300 px-6 py-3 text-sm font-bold text-brand-900 transition hover:bg-white" %>
  </div>
</section>

<!-- FEATURED ARTICLES -->
<section class="bg-brand-50 py-20 sm:py-24">
  <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
    <h2 class="font-serif text-4xl font-medium text-brand-900">Want to know more?</h2>
    <p class="mt-2 text-base text-slate-600">Read our latest insights on TMT M&amp;A.</p>
    <div class="mt-10 grid gap-5 sm:grid-cols-2">
      <% [
        ["The state of TMT M&A in 2026", "Insights"],
        ["How AI is reshaping small-business dealmaking", "Insights"],
        ["What buyers really pay for in SaaS", "Insights"],
        ["Selling your MSP: a step-by-step guide", "Insights"]
      ].each do |title, tag| %>
        <%= link_to insights_path, class: "block rounded-sm border border-brand-100 bg-white p-6 shadow-soft transition hover:-translate-y-0.5" do %>
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-brand-300"><%= tag %></p>
          <h3 class="mt-2 font-serif text-2xl font-medium text-brand-900"><%= title %></h3>
          <span class="mt-3 inline-flex items-center gap-1 text-sm font-semibold text-brand-500">Read more →</span>
        <% end %>
      <% end %>
    </div>
  </div>
</section>
