<section class="relative isolate min-h-screen overflow-hidden text-white">

  <!-- Background Image -->
  <div
    class="absolute inset-0 bg-cover bg-center"
    style="background-image: url('<%= asset_path("hero-buyers.png") %>');">
  </div>

  <!-- Brand Overlay -->
  <div class="absolute inset-0 bg-brand-900/35"></div>

  <!-- Gradient -->
  <div class="absolute inset-0 bg-gradient-to-r from-brand-900/75 via-brand-900/40 to-transparent"></div>

  <div class="relative z-10 mx-auto flex min-h-screen max-w-7xl flex-col justify-center px-4 pb-20 pt-32 sm:px-6 lg:px-8">

    <div class="max-w-3xl animate-fade-up">

      <div class="mb-6 inline-flex items-center rounded-full bg-white/10 px-5 py-2 text-sm text-white backdrop-blur-sm">
        For qualified buyers seeking TMT acquisition opportunities
      </div>

      <h1 class="font-serif text-5xl font-medium leading-[0.95] tracking-tight text-white sm:text-6xl lg:text-7xl">
        Find Your Next
        <span class="text-brand-300">
          TMT Acquisition
        </span>
      </h1>

      <p class="mt-6 max-w-2xl text-xl leading-8 text-white/80">
        Join the AcquireTMT Buyer Network to access curated technology, media, telecom, digital infrastructure, SaaS, MSP, and tech-enabled services acquisition opportunities.
      </p>

      <div class="mt-8 flex flex-col gap-3 sm:flex-row">
        <%= link_to contact_path,
          class: "inline-flex items-center justify-center rounded-sm bg-brand-300 px-6 py-4 text-sm font-bold text-brand-900 transition duration-300 hover:bg-white hover:scale-[1.02]" do %>
          Join Buyer Network
        <% end %>

        <%= link_to tools_market_comps_path,
          class: "inline-flex items-center justify-center rounded-sm border border-white/20 px-6 py-4 text-sm font-bold text-white transition duration-300 hover:bg-white/10 hover:scale-[1.02]" do %>
          View Market Comps
        <% end %>
      </div>
    </div>

    <!-- Bottom Stats -->
    <div class="mt-20 grid gap-8 border-t border-white/15 pt-8 md:grid-cols-2 lg:grid-cols-4">
      <% [
        ["Curated TMT Deals", "Relevant opportunities aligned with your acquisition criteria."],
        ["Qualified Materials", "Teasers, CIMs, financial snapshots, and seller materials."],
        ["Direct Process", "Seller or advisor-led conversations with qualified buyers."],
        ["No Buyer Fees", "Review opportunities without acquisition-side finder fees."]
      ].each do |title, description| %>

        <div class="border-l border-white/20 pl-5">
          <h3 class="font-serif text-2xl font-medium text-white">
            <%= title %>
          </h3>

          <p class="mt-3 text-sm leading-6 text-white/70">
            <%= description %>
          </p>
        </div>

      <% end %>
    </div>

  </div>
</section>

<section class="bg-brand-50 py-24 sm:py-28">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">

    <div class="mx-auto max-w-4xl text-center">
      <p class="text-sm font-semibold uppercase tracking-[0.2em] text-brand-300">
        Buyer types
      </p>

      <h2 class="mt-5 font-serif text-4xl font-medium leading-tight text-brand-900 sm:text-5xl">
        Built for serious
        <span class="text-brand-300">
          TMT acquirers.
        </span>
      </h2>

      <p class="mx-auto mt-5 max-w-2xl text-lg leading-8 text-slate-600">
        AcquireTMT supports buyers actively looking for quality technology, telecom, media, SaaS, cloud, and digital infrastructure acquisitions.
      </p>
    </div>

    <div class="mt-16 grid gap-6 sm:grid-cols-2 xl:grid-cols-3">

      <% [
        [
          "Private Equity",
          "Platform and add-on acquisitions across technology-enabled sectors.",
          "briefcase"
        ],
        [
          "Strategic Acquirers",
          "Corporate buyers seeking expansion, capabilities, or market access.",
          "building-2"
        ],
        [
          "Search Funds",
          "Operators seeking founder-led and cash-flowing acquisitions.",
          "search"
        ],
        [
          "Independent Sponsors",
          "Deal-by-deal acquirers sourcing proprietary opportunities.",
          "wallet"
        ],
        [
          "Family Offices",
          "Long-term capital seeking quality TMT businesses.",
          "landmark"
        ],
        [
          "Corporate Development Teams",
          "Internal M&A teams evaluating acquisition opportunities.",
          "network"
        ]
      ].each do |title, description, icon| %>

        <div class="group rounded-sm border border-brand-100 bg-white p-8 transition duration-300 hover:-translate-y-1 hover:shadow-soft">
          <div class="flex h-14 w-14 items-center justify-center rounded-full bg-brand-50">
            <%= lucide_icon icon,
              class: "h-6 w-6 text-brand-900" %>
          </div>

          <h3 class="mt-6 font-serif text-3xl font-medium text-brand-900">
            <%= title %>
          </h3>

          <p class="mt-4 text-sm leading-7 text-slate-600">
            <%= description %>
          </p>
        </div>

      <% end %>

    </div>

  </div>
</section>
<section class="bg-white py-24 sm:py-28">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-4xl text-center">
      <p class="text-sm font-semibold uppercase tracking-[0.2em] text-brand-300">
        What buyers get
      </p>

      <h2 class="mt-5 font-serif text-4xl font-medium leading-tight text-brand-900 sm:text-5xl">
        Curated, diligence-ready TMT opportunities.
      </h2>
    </div>

    <div class="mt-14 grid gap-px overflow-hidden rounded-sm bg-brand-100 sm:grid-cols-2 lg:grid-cols-3">
      <% [
        ["Curated TMT Deal Alerts", "Receive acquisition opportunities matched to your mandate."],
        ["Deal Teasers", "Review concise seller-approved opportunity summaries."],
        ["CIM Access", "Access buyer-facing materials after qualification."],
        ["Financial Snapshots", "Review revenue, EBITDA, ARR/MRR, customer mix, and growth context."],
        ["Data Room Access After NDA", "Access diligence materials after NDA and seller approval."],
        ["Seller / Advisor Meetings", "Engage through a structured seller or advisor-led process."]
      ].each do |title, description| %>

        <div class="bg-white p-8 hover-lift">
          <h3 class="font-serif text-3xl font-medium text-brand-900"><%= title %></h3>
          <p class="mt-4 text-sm leading-7 text-slate-600"><%= description %></p>
        </div>

      <% end %>
    </div>
  </div>
</section>
<section id="buyer-network-form" class="bg-brand-50 py-24 sm:py-28">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid gap-12 lg:grid-cols-12 lg:items-start">
      <div class="lg:col-span-5 animate-fade-up">
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-brand-300">
          Mandate form
        </p>

        <h2 class="mt-5 font-serif text-4xl font-medium leading-tight text-brand-900 sm:text-5xl">
          Share your acquisition criteria.
        </h2>

        <p class="mt-5 text-lg leading-8 text-slate-600">
          Tell us your preferred sectors, acquisition size, geography, and mandate focus so AcquireTMT can match you with relevant TMT opportunities.
        </p>
      </div>

      <div class="lg:col-span-7">
        <div class="rounded-sm border border-brand-100 bg-white p-8 shadow-soft">
          <%= form_with model: Lead.new, url: leads_path, class: "space-y-6" do |f| %>
            <%= f.hidden_field :source, value: "buyer_network" %>

            <div class="grid gap-5 sm:grid-cols-2">
              <div>
                <%= f.label :first_name, class: "mb-2 block text-sm font-semibold text-brand-900" %>
                <%= f.text_field :first_name, class: "w-full rounded-sm border border-brand-100 px-4 py-3" %>
              </div>

              <div>
                <%= f.label :last_name, class: "mb-2 block text-sm font-semibold text-brand-900" %>
                <%= f.text_field :last_name, class: "w-full rounded-sm border border-brand-100 px-4 py-3" %>
              </div>
            </div>

            <div class="grid gap-5 sm:grid-cols-2">
              <div>
                <%= f.label :email, class: "mb-2 block text-sm font-semibold text-brand-900" %>
                <%= f.email_field :email, class: "w-full rounded-sm border border-brand-100 px-4 py-3" %>
              </div>

              <div>
                <%= f.label :phone, class: "mb-2 block text-sm font-semibold text-brand-900" %>
                <%= f.telephone_field :phone, class: "w-full rounded-sm border border-brand-100 px-4 py-3" %>
              </div>
            </div>

            <div>
              <%= f.label :company_name, "Firm / Company Name", class: "mb-2 block text-sm font-semibold text-brand-900" %>
              <%= f.text_field :company_name, class: "w-full rounded-sm border border-brand-100 px-4 py-3" %>
            </div>

            <div class="grid gap-5 sm:grid-cols-2">
              <div>
                <%= f.label :company_type, "Buyer Type", class: "mb-2 block text-sm font-semibold text-brand-900" %>
                <%= f.select :company_type,
                  ["Private Equity", "Strategic Acquirer", "Search Fund", "Independent Sponsor", "Family Office", "Corporate Development Team"],
                  {},
                  class: "w-full rounded-sm border border-brand-100 bg-white px-4 py-3" %>
              </div>

              <div>
                <%= f.label :revenue_range, "Target Revenue Range", class: "mb-2 block text-sm font-semibold text-brand-900" %>
                <%= f.select :revenue_range,
                  ["Under $1M", "$1M - $5M", "$5M - $25M", "$25M - $100M", "$100M+"],
                  {},
                  class: "w-full rounded-sm border border-brand-100 bg-white px-4 py-3" %>
              </div>
            </div>

            <div>
              <%= f.label :message, "Acquisition Criteria", class: "mb-2 block text-sm font-semibold text-brand-900" %>
              <%= f.text_area :message,
                rows: 5,
                placeholder: "Sectors, geography, deal size, EBITDA range, preferred business models, and mandate focus.",
                class: "w-full rounded-sm border border-brand-100 px-4 py-3" %>
            </div>

            <%= f.submit "Join Buyer Network",
              class: "w-full rounded-sm bg-brand-900 px-6 py-4 text-sm font-bold text-white transition duration-300 hover:bg-brand-500" %>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</section>
<section class="bg-white py-24 sm:py-28">
  <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
    <div class="text-center">
      <p class="text-sm font-semibold uppercase tracking-[0.2em] text-brand-300">
        Buyer FAQ
      </p>

      <h2 class="mt-5 font-serif text-4xl font-medium leading-tight text-brand-900 sm:text-5xl">
        Common questions from buyers.
      </h2>
    </div>

    <div class="mt-14 divide-y divide-slate-200 border-y border-slate-200">
      <% [
        [
          "Who can join the AcquireTMT Buyer Network?",
          "Private equity firms, strategic acquirers, search funds, independent sponsors, family offices, and corporate development teams."
        ],
        [
          "What kind of opportunities will I receive?",
          "Curated TMT acquisition opportunities across SaaS, telecom, media, MSPs, cloud, cybersecurity, digital infrastructure, and tech-enabled services."
        ],
        [
          "Do buyers pay a finder fee?",
          "No. The buyer network is designed to give qualified buyers access to relevant opportunities without buyer-side finder fees."
        ],
        [
          "When can I access CIMs and data rooms?",
          "CIMs, financial snapshots, and data rooms are typically shared after qualification, NDA, and seller approval."
        ],
        [
          "How are opportunities matched?",
          "AcquireTMT uses buyer criteria such as sector focus, size range, geography, business model, and mandate fit."
        ]
      ].each do |question, answer| %>

        <details class="group py-6">
          <summary class="flex cursor-pointer list-none items-center justify-between gap-4">
            <h3 class="font-serif text-2xl font-medium text-brand-900">
              <%= question %>
            </h3>

            <span class="transition group-open:rotate-45">
              <%= lucide_icon "plus", class: "h-5 w-5 text-brand-900" %>
            </span>
          </summary>

          <p class="mt-4 text-base leading-8 text-slate-600">
            <%= answer %>
          </p>
        </details>

      <% end %>
    </div>
  </div>
</section>
<section class="bg-brand-900 py-24 text-white sm:py-28">
  <div class="mx-auto max-w-5xl px-4 text-center sm:px-6 lg:px-8">
    <h2 class="font-serif text-4xl font-medium leading-tight text-white sm:text-5xl lg:text-6xl">
      Join the AcquireTMT
      <br>
      <span class="text-brand-300">Buyer Network.</span>
    </h2>

    <p class="mx-auto mt-6 max-w-2xl text-lg leading-8 text-white/70">
      Share your acquisition criteria and receive curated TMT opportunities aligned with your mandate.
    </p>

    <div class="mt-8">
      <a href="#buyer-network-form"
        class="inline-flex items-center justify-center rounded-sm bg-brand-300 px-6 py-4 text-sm font-bold text-brand-900 transition duration-300 hover:bg-white hover:scale-[1.02]">
        Submit Buyer Criteria
      </a>
    </div>
  </div>
</section>