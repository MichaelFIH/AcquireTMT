<section class="min-h-screen bg-brand-50 py-24 sm:py-28">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8" data-controller="valuation">

    <%= form_with model: Lead.new, url: leads_path do |f| %>
      <%= f.hidden_field :source, value: "valuation_snapshot" %>

      <!-- STEP 1: WEBSITE -->
      <div data-valuation-target="websiteStep" class="mx-auto max-w-5xl text-center">
        <div class="inline-flex items-center gap-2 rounded-full bg-white px-4 py-2 text-sm font-semibold text-brand-900 shadow-soft">
          <%= lucide_icon "sparkles", class: "h-4 w-4 text-brand-300" %>
          TMT Valuation Snapshot
        </div>

        <h1 class="mt-6 font-serif text-5xl font-medium leading-tight text-brand-900 sm:text-6xl lg:text-7xl">
          Get an instant valuation view
          <br>
          for your TMT business
        </h1>

        <p class="mx-auto mt-5 max-w-2xl text-lg leading-8 text-slate-600">
          Receive a preliminary valuation snapshot based on revenue, profit, value drivers, market comps, and buyer demand.
        </p>

        <div class="mx-auto mt-10 max-w-xl rounded-sm border border-brand-100 bg-white p-6 shadow-soft">
          <%= f.label :company_website, "Enter your company website", class: "mb-2 block text-left font-serif text-2xl font-medium text-brand-900" %>

          <%= f.url_field :company_website,
            placeholder: "Company website URL",
            data: { valuation_target: "websiteInput" },
            class: "w-full rounded-sm border border-brand-100 px-4 py-4 text-sm text-brand-900 placeholder:text-slate-400" %>

          <button
            type="button"
            data-action="valuation#showFinancials"
            class="mt-5 w-full rounded-sm bg-brand-900 px-6 py-4 text-sm font-bold text-white transition hover:bg-brand-500">
            Next
          </button>

          <p class="mt-4 text-center text-xs text-slate-500">
            No email required to preview. 100% confidential.
          </p>
        </div>
      </div>

      <!-- STEP 2: FINANCIAL DATA -->
      <div data-valuation-target="financialStep" class="mx-auto hidden max-w-6xl">
        <div class="grid gap-8 lg:grid-cols-2 lg:items-stretch">

          <div class="rounded-sm border border-brand-100 bg-white p-8 shadow-soft">
            <div class="flex items-start justify-between gap-6">
              <h2 class="font-serif text-4xl font-medium leading-tight text-brand-900">
                Now, let’s get some basic financial data
              </h2>

              <span class="font-serif text-2xl text-brand-900">2/2</span>
            </div>

            <div class="mt-8 border-t border-brand-100 pt-8">
              <div>
                <%= f.label :revenue_range, "Revenue", class: "mb-2 block text-sm font-semibold text-slate-600" %>
                <%= number_field_tag "valuation_revenue",
                  nil,
                  min: 0,
                  placeholder: "What were your 2025 sales?",
                  data: { valuation_target: "revenueInput" },
                  class: "w-full rounded-sm border border-brand-100 px-4 py-4 text-sm text-brand-900" %>
              </div>

              <div class="mt-5">
                <%= f.label :profit_range, "Pre-Tax Profit", class: "mb-2 block text-sm font-semibold text-slate-600" %>
                <%= number_field_tag "valuation_profit",
                  nil,
                  min: 0,
                  placeholder: "What is your net profit before taxes?",
                  data: { valuation_target: "profitInput" },
                  class: "w-full rounded-sm border border-brand-100 px-4 py-4 text-sm text-brand-900" %>
              </div>

              <div class="mt-5">
                <%= label_tag "valuation_salary", "Owner Salary", class: "mb-2 block text-sm font-semibold text-slate-600" %>
                <%= number_field_tag "valuation_salary",
                  nil,
                  min: 0,
                  placeholder: "How much do you pay yourself?",
                  data: { valuation_target: "salaryInput" },
                  class: "w-full rounded-sm border border-brand-100 px-4 py-4 text-sm text-brand-900" %>
              </div>

              <button
                type="button"
                data-action="valuation#startReport"
                class="mt-8 w-full rounded-sm bg-brand-900 px-6 py-4 text-sm font-bold text-white transition hover:bg-brand-500">
                Generate Valuation Report
              </button>

              <button
                type="button"
                data-action="valuation#backToWebsite"
                class="mt-3 w-full rounded-sm border border-brand-100 px-6 py-4 text-sm font-bold text-brand-900 hover:bg-brand-50">
                Back
              </button>

              <p class="mt-6 text-center text-sm leading-6 text-slate-500">
                Free instant valuation. No email or sign-up necessary.
              </p>
            </div>
          </div>

          <div class="rounded-sm border border-brand-100 bg-white p-8 shadow-soft">
            <h3 class="font-serif text-4xl font-medium text-brand-900">
              <span data-valuation-target="companyName">Your Business</span>
            </h3>

            <div class="mt-4 space-y-3">
              <div class="h-4 w-full rounded-full bg-brand-50"></div>
              <div class="h-4 w-10/12 rounded-full bg-brand-50"></div>
              <div class="h-4 w-8/12 rounded-full bg-brand-50"></div>
            </div>

            <div class="mt-6 flex items-center gap-2 border-b border-brand-100 pb-6 text-sm text-slate-600">
              <%= lucide_icon "globe", class: "h-4 w-4" %>
              www.company.com
            </div>

            <div class="mt-8">
              <p class="text-lg font-semibold text-brand-900">Products & Services</p>

              <div class="mt-4 grid gap-3 sm:grid-cols-2">
                <div class="h-10 rounded-sm bg-brand-50"></div>
                <div class="h-10 rounded-sm bg-brand-50"></div>
                <div class="h-10 rounded-sm bg-brand-50"></div>
                <div class="h-10 rounded-sm bg-brand-50"></div>
              </div>
            </div>

            <div class="mt-8 border-t border-brand-100 pt-8">
              <p class="text-lg font-semibold text-brand-900">End Markets</p>

              <div class="mt-4 grid gap-3 sm:grid-cols-3">
                <div class="h-10 rounded-sm bg-brand-50"></div>
                <div class="h-10 rounded-sm bg-brand-50"></div>
                <div class="h-10 rounded-sm bg-brand-50"></div>
                <div class="h-10 rounded-sm bg-brand-50 sm:col-span-2"></div>
              </div>
            </div>
          </div>

        </div>
      </div>

      <!-- STEP 3: PROCESSING -->
<div data-valuation-target="loadingStep" class="mx-auto hidden max-w-6xl">
  <div class="grid gap-8 lg:grid-cols-2 lg:items-stretch">

    <!-- Left Processing -->
    <div class="rounded-sm border border-brand-100 bg-white p-8 shadow-soft">
      <p class="text-sm font-semibold uppercase tracking-[0.2em] text-brand-300">
        Preparing valuation snapshot
      </p>

      <h2 class="mt-5 font-serif text-4xl font-medium text-brand-900">
        Building your valuation report...
      </h2>

      <div class="mt-8">
        <div class="flex items-center justify-between text-sm font-bold text-brand-900">
          <span data-valuation-target="loadingTitle">Analyzing website</span>
          <span data-valuation-target="progressText">0%</span>
        </div>

        <div class="mt-3 h-3 overflow-hidden rounded-full bg-brand-50">
          <div
            data-valuation-target="progressBar"
            class="h-full w-0 rounded-full bg-brand-300 transition-all duration-300">
          </div>
        </div>

        <p data-valuation-target="loadingDescription" class="mt-4 text-sm leading-6 text-slate-600">
          Reviewing company signals and business model.
        </p>
      </div>

      <div data-valuation-target="stepList" class="mt-8 space-y-3"></div>
    </div>

    <!-- Right Company Preview -->
    <div class="rounded-sm border border-brand-100 bg-white p-8 shadow-soft">
      <h3 class="font-serif text-4xl font-medium text-brand-900">
        <span data-valuation-target="companyName">Your Business</span>
      </h3>

      <div class="mt-4 space-y-3">
        <div class="h-4 w-full rounded-full bg-slate-200"></div>
        <div class="h-4 w-10/12 rounded-full bg-slate-200"></div>
        <div class="h-4 w-8/12 rounded-full bg-slate-200"></div>
      </div>

      <div class="mt-6 flex items-center gap-2 border-b border-brand-100 pb-6 text-sm text-slate-600">
        <%= lucide_icon "globe", class: "h-4 w-4" %>
        www.company.com
      </div>

      <div class="mt-8">
        <p class="text-lg font-semibold text-brand-900">Products & Services</p>

        <div class="mt-4 grid gap-3 sm:grid-cols-2">
          <div class="h-10 rounded-sm bg-slate-200"></div>
          <div class="h-10 rounded-sm bg-slate-200"></div>
          <div class="h-10 rounded-sm bg-slate-200"></div>
          <div class="h-10 rounded-sm bg-slate-200"></div>
        </div>
      </div>

      <div class="mt-8 border-t border-brand-100 pt-8">
        <p class="text-lg font-semibold text-brand-900">End Markets</p>

        <div class="mt-4 grid gap-3 sm:grid-cols-3">
          <div class="h-10 rounded-sm bg-slate-200"></div>
          <div class="h-10 rounded-sm bg-slate-200"></div>
          <div class="h-10 rounded-sm bg-slate-200"></div>
          <div class="h-10 rounded-sm bg-slate-200 sm:col-span-2"></div>
        </div>
      </div>
    </div>

  </div>
</div>

      <!-- STEP 4: REPORT -->
<div data-valuation-target="reportStep" class="hidden">
  <div class="mx-auto max-w-5xl text-center">
    <h2 class="font-serif text-5xl font-medium text-brand-900">
      <span data-valuation-target="companyName">Your Business</span> Report is Ready
    </h2>

    <div class="mt-10 flex flex-col items-center justify-center gap-6 sm:flex-row">
      <div class="flex items-center gap-3">
        <span data-valuation-target="stepOneIndicator" class="flex h-10 w-10 items-center justify-center rounded-full bg-brand-300 font-bold text-brand-900">1</span>
        <div class="text-left">
          <p class="text-sm text-slate-500">Step 1</p>
          <p class="font-bold text-brand-900">Deal Comps</p>
        </div>
      </div>

      <div class="hidden h-px w-16 bg-brand-100 sm:block"></div>

      <div class="flex items-center gap-3">
        <span data-valuation-target="stepTwoIndicator" class="flex h-10 w-10 items-center justify-center rounded-full bg-slate-300 font-bold text-white">2</span>
        <div class="text-left">
          <p class="text-sm text-slate-500">Step 2</p>
          <p class="font-bold text-brand-900">Value Drivers</p>
        </div>
      </div>

      <div class="hidden h-px w-16 bg-brand-100 sm:block"></div>

      <div class="flex items-center gap-3">
        <span data-valuation-target="stepThreeIndicator" class="flex h-10 w-10 items-center justify-center rounded-full bg-slate-300 font-bold text-white">3</span>
        <div class="text-left">
          <p class="text-sm text-slate-500">Step 3</p>
          <p class="font-bold text-brand-900">Business Valuation</p>
        </div>
      </div>
    </div>
  </div>

  <div class="mx-auto mt-12 max-w-5xl rounded-sm border border-brand-100 bg-white shadow-soft">

    <!-- DEAL COMPS -->
    <div data-valuation-target="dealCompsStep">
      <div class="flex items-center justify-between border-b border-brand-100 p-6">
        <button type="button" class="rounded-full border border-brand-100 px-5 py-2 text-sm font-bold text-slate-400">
          Prev Step
        </button>

        <button type="button" data-action="valuation#showValueDrivers" class="rounded-full bg-brand-900 px-5 py-2 text-sm font-bold text-white">
          Next Step
        </button>
      </div>

      <div class="p-8">
        <h3 class="text-2xl font-bold text-brand-900">Relevant Transactions in Your Space</h3>
        <p class="mt-2 text-sm text-slate-600">Recently closed deals in your sector.</p>

        <div class="relative mt-8 overflow-hidden rounded-sm border border-brand-100">
          <table class="w-full text-left text-sm">
            <thead class="bg-brand-50 text-slate-600">
              <tr>
                <th class="p-4">Company</th>
                <th class="p-4">Revenue</th>
                <th class="p-4">EBITDA</th>
                <th class="p-4">SDE</th>
                <th class="p-4">Sold for</th>
              </tr>
            </thead>

            <tbody class="blur-sm">
              <% 5.times do %>
                <tr class="border-t border-brand-100">
                  <td class="p-4">TMT Business</td>
                  <td class="p-4">$2.8M</td>
                  <td class="p-4">$610k</td>
                  <td class="p-4">$720k</td>
                  <td class="p-4">$3.4M</td>
                </tr>
              <% end %>
            </tbody>
          </table>

          <div class="absolute inset-0 flex items-center justify-center bg-white/60 px-4 backdrop-blur-sm">
            <div class="max-w-lg rounded-sm bg-white p-8 shadow-soft">
              <h4 class="font-serif text-3xl font-medium text-brand-900">
                View All Relevant Transactions
              </h4>

              <p class="mt-3 text-sm leading-6 text-slate-600">
                Review comparable sales, benchmark your business, and plan your next steps.
              </p>

              <button type="button" data-action="valuation#showValueDrivers" class="mt-5 rounded-sm bg-brand-300 px-6 py-3 text-sm font-bold text-brand-900">
                Review Deal Comps
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- VALUE DRIVERS -->
    <div data-valuation-target="valueDriversStep" class="hidden">
      <div class="flex items-center justify-between border-b border-brand-100 p-6">
        <button type="button" data-action="valuation#showDealComps" class="rounded-full border border-brand-100 px-5 py-2 text-sm font-bold text-brand-900">
          Prev Step
        </button>

        <button type="button" data-action="valuation#showBusinessValuation" class="rounded-full bg-brand-900 px-5 py-2 text-sm font-bold text-white">
          Next Step
        </button>
      </div>

      <div class="p-8">
        <h3 class="text-2xl font-bold text-brand-900">Value Drivers</h3>
        <p class="mt-2 text-sm text-slate-600">Specific factors that affect your business valuation.</p>

        <div class="mt-8 rounded-sm border border-emerald-100 bg-emerald-50">
          <div class="border-b border-emerald-100 px-5 py-4">
            <p class="font-bold text-brand-900">Positive Impact</p>
          </div>

          <div class="space-y-6 p-6">
            <% [
              ["Recurring Revenue Streams", "Recurring SaaS, telecom, MSP, or contracted revenue can improve buyer confidence."],
              ["Strong Margin Profile", "Healthy EBITDA and controlled operating costs may support stronger valuation multiples."],
              ["Diverse Customer Base", "Lower customer concentration can reduce buyer risk and improve deal confidence."]
            ].each do |title, description| %>
              <div class="flex gap-4">
                <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-sm bg-white">
                  <%= lucide_icon "chart-column", class: "h-5 w-5 text-brand-900" %>
                </div>

                <div>
                  <h4 class="font-bold text-brand-900"><%= title %></h4>
                  <p class="mt-1 text-sm leading-6 text-slate-600"><%= description %></p>
                </div>
              </div>
            <% end %>
          </div>
        </div>

        <div class="relative mt-8 overflow-hidden rounded-sm border border-red-100 bg-red-50">
          <div class="border-b border-red-100 px-5 py-4">
            <p class="font-bold text-brand-900">Negative Impact</p>
          </div>

          <div class="space-y-6 p-6 blur-sm">
            <div class="flex gap-4">
              <div class="h-10 w-10 rounded-sm bg-white"></div>
              <div class="flex-1">
                <div class="h-4 w-1/2 rounded bg-white"></div>
                <div class="mt-3 h-3 w-full rounded bg-white"></div>
                <div class="mt-2 h-3 w-10/12 rounded bg-white"></div>
              </div>
            </div>
          </div>

          <div class="absolute inset-0 flex items-center justify-center bg-white/50 px-4 backdrop-blur-sm">
            <div class="max-w-lg rounded-sm bg-white p-7 shadow-soft">
              <h4 class="font-serif text-3xl font-medium text-brand-900">
                View All Relevant Value Drivers
              </h4>

              <p class="mt-3 text-sm leading-6 text-slate-600">
                Book a free call with an M&A advisor to unpack how each driver helps or hurts your valuation.
              </p>

              <button type="button" data-action="valuation#showBusinessValuation" class="mt-5 rounded-sm bg-brand-300 px-6 py-3 text-sm font-bold text-brand-900">
                Review Value Drivers
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- BUSINESS VALUATION + FORM ONLY HERE -->
    <div data-valuation-target="businessValuationStep" class="hidden">
      <div class="flex items-center justify-between border-b border-brand-100 p-6">
        <button type="button" data-action="valuation#showValueDrivers" class="rounded-full border border-brand-100 px-5 py-2 text-sm font-bold text-brand-900">
          Prev Step
        </button>

        <button type="button" class="rounded-full bg-slate-100 px-5 py-2 text-sm font-bold text-white">
          Next Step
        </button>
      </div>

      <div class="p-8">
        <h3 class="text-2xl font-bold text-brand-900">Valuation Overview</h3>
        <p class="mt-2 text-sm text-slate-600">
          Your business valuation based on different approaches and market data.
        </p>

        <div class="mt-10 text-center">
          <p class="text-sm text-slate-600">Estimated Value Range</p>

          <p class="mt-3 font-serif text-6xl font-medium text-brand-900">
            $231K - $313K
          </p>

          <p class="mt-4 text-sm text-slate-600">Valuation based on:</p>

          <div class="mt-3 flex flex-wrap justify-center gap-2">
            <span class="rounded-full bg-brand-50 px-4 py-2 text-xs font-semibold text-brand-900">Business Details</span>
            <span class="rounded-full bg-brand-50 px-4 py-2 text-xs font-semibold text-brand-900">Similar Deals</span>
            <span class="rounded-full bg-brand-50 px-4 py-2 text-xs font-semibold text-brand-900">Market Trends</span>
          </div>
        </div>

        <div class="relative mt-10 overflow-hidden rounded-sm border border-brand-100">
          <table class="w-full text-left text-sm">
            <thead class="bg-brand-50 text-slate-600">
              <tr>
                <th class="p-4">Approach</th>
                <th class="p-4">Valuation Range</th>
                <th class="p-4">Multiplier</th>
              </tr>
            </thead>

            <tbody>
              <tr class="border-t border-brand-100">
                <td class="p-4">SDE-based</td>
                <td class="p-4">$231K — $313K</td>
                <td class="p-4">2.9x - 3.9x</td>
              </tr>
              <tr class="border-t border-brand-100">
                <td class="p-4">EBITDA-based</td>
                <td class="p-4">$327K — $443K</td>
                <td class="p-4">4.7x - 6.3x</td>
              </tr>
              <tr class="border-t border-brand-100 blur-sm">
                <td class="p-4">Revenue-based</td>
                <td class="p-4">$410K — $620K</td>
                <td class="p-4">1.8x - 2.5x</td>
              </tr>
            </tbody>
          </table>
        </div>

        <div class="mx-auto mt-10 max-w-xl rounded-sm bg-brand-900 p-7 text-white shadow-soft">
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-brand-300">
            Claim your free M&A expert session
          </p>

          <h4 class="mt-3 font-serif text-3xl font-medium text-white">
            Take the first step today.
          </h4>

          <p class="mt-2 text-sm leading-6 text-white/70">
            Turn buyer interest into competing offers and get acquired on better terms.
          </p>

          <div class="mt-5 space-y-3">
            <%= f.text_field :first_name,
              placeholder: "Full Name",
              class: "w-full rounded-sm border border-white/10 bg-white px-4 py-3 text-sm text-brand-900 placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-brand-300" %>

            <%= f.email_field :email,
              placeholder: "Email Address",
              class: "w-full rounded-sm border border-white/10 bg-white px-4 py-3 text-sm text-brand-900 placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-brand-300" %>

            <%= f.telephone_field :phone,
              placeholder: "Mobile Number",
              class: "w-full rounded-sm border border-white/10 bg-white px-4 py-3 text-sm text-brand-900 placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-brand-300" %>

            <%= f.select :message,
              ["When are you looking to sell?", "Immediately", "3-6 months", "6-12 months", "Just exploring"],
              {},
              class: "w-full rounded-sm border border-white/10 bg-white px-4 py-3 text-sm text-brand-900 focus:outline-none focus:ring-2 focus:ring-brand-300" %>

            <%= f.submit "Book 15 minute call",
              class: "w-full rounded-sm bg-brand-300 px-6 py-4 text-sm font-bold text-brand-900 transition hover:bg-white" %>
          </div>

          <p class="mt-4 text-center text-xs text-white/60">
            No commitment, just a 15 minute chat.
          </p>
        </div>
      </div>
    </div>
  </div>
</div>

    <% end %>
  </div>
</section>
<section class="bg-white py-24 sm:py-28">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-4xl text-center">
      <p class="text-sm font-semibold uppercase tracking-[0.2em] text-brand-300">
        What you get
      </p>

      <h2 class="mt-5 font-serif text-4xl font-medium text-brand-900 sm:text-5xl">
        A clearer view of what your TMT business may be worth.
      </h2>
    </div>

    <div class="mt-14 grid gap-px overflow-hidden rounded-sm bg-brand-100 sm:grid-cols-2 lg:grid-cols-4">
      <% [
        ["Valuation Range", "A preliminary estimate based on revenue, profit, multiples, and market context."],
        ["Deal Comps", "Relevant transaction examples and comparable business activity."],
        ["Value Drivers", "Factors that may increase or reduce valuation in a buyer process."],
        ["Advisor Review", "A path to discuss your valuation with an AcquireTMT advisor."]
      ].each do |title, description| %>
        <div class="bg-white p-7 hover-lift">
          <h3 class="font-serif text-2xl font-medium text-brand-900"><%= title %></h3>
          <p class="mt-3 text-sm leading-6 text-slate-600"><%= description %></p>
        </div>
      <% end %>
    </div>
  </div>
</section>
<section class="bg-white py-24 sm:py-28 data-controller="carousel">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">

    <div class="flex flex-col gap-8 lg:flex-row lg:items-end lg:justify-between">
      <div>
        <h2 class="font-serif text-4xl font-medium text-brand-900 sm:text-5xl">
          What you’ll get
        </h2>

        <div class="mt-5 flex gap-2">
          <button
            type="button"
            data-action="carousel#scrollLeft"
            class="flex h-10 w-10 items-center justify-center rounded-full border border-brand-100 text-brand-900 transition hover:bg-brand-50">
            <%= lucide_icon "chevron-left", class: "h-4 w-4" %>
          </button>

          <button
            type="button"
            data-action="carousel#scrollRight"
            class="flex h-10 w-10 items-center justify-center rounded-full border border-brand-100 text-brand-900 transition hover:bg-brand-50">
            <%= lucide_icon "chevron-right", class: "h-4 w-4" %>
          </button>
        </div>
      </div>

      <div class="max-w-md">
        <p class="text-sm leading-6 text-slate-600">
          A detailed and personalized valuation snapshot produced from your company profile, market signals, and comparable deal context.
        </p>

        <a href="#"
          class="mt-5 inline-flex rounded-sm bg-brand-900 px-5 py-3 text-sm font-bold text-white transition hover:bg-brand-500">
          Get Free Valuation
        </a>
      </div>
    </div>

    <!-- Carousel -->
    <div class="mt-14">

      <div
  data-carousel-target="track"
  class="flex cursor-grab snap-x snap-mandatory gap-6 overflow-x-auto scroll-smooth pb-4 active:cursor-grabbing [-ms-overflow-style:none] [scrollbar-width:none] [&::-webkit-scrollbar]:hidden">

        <% [
          [
            "AI-powered valuation based on market data",
            "Get an instant valuation based on recent M&A transactions and market signals.",
            "valuation-card-1.png",
            "chart-column"
          ],
          [
            "Data-backed snapshot of your market position",
            "Quickly see how your business compares to competitors.",
            "valuation-card-2.png",
            "chart-scatter"
          ],
          [
            "Personalized valuation insights for your business",
            "Understand what specific factors may increase or reduce your valuation.",
            "valuation-card-3.png",
            "trending-up"
          ],
          [
            "Market sector valuation benchmarks",
            "Review what owners in your category are asking and selling for.",
            "valuation-card-4.png",
            "chart-bar"
          ],
          [
            "Comparable M&A transaction signals",
            "Preview relevant transaction patterns and pricing benchmarks.",
            "valuation-card-5.png",
            "briefcase-business"
          ]
        ].each do |title, description, image, icon| %>

          <div data-carousel-card class="min-w-[88%] sm:min-w-[48%] lg:min-w-[31%] snap-start overflow-hidden rounded-sm border border-brand-100 bg-brand-50 transition duration-300 hover:-translate-y-1 hover:shadow-soft">

            <!-- Top -->
            <div class="p-7">
              <%= lucide_icon icon,
                class: "h-6 w-6 text-brand-900" %>

              <h3 class="mt-5 font-serif text-3xl font-medium leading-tight text-brand-900">
                <%= title %>
              </h3>
            </div>

            <!-- Image -->
            <div class="px-7">
              <%= image_tag image,
                class: "h-72 w-full rounded-sm object-contain",
                alt: title %>
            </div>

            <!-- Bottom -->
            <div class="p-7">
              <p class="text-sm leading-6 text-slate-600">
                <%= description %>
              </p>
            </div>

          </div>

        <% end %>

      </div>
    </div>

  </div>
</section>

<section class="bg-white py-20">
  <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
    <div class="rounded-sm bg-brand-900 p-8 text-white shadow-soft sm:p-10">
      <h2 class="font-serif text-3xl font-medium text-white">
        Get an instant business valuation
      </h2>

      <div class="mt-6 flex flex-col gap-3 sm:flex-row">
        <input
          type="url"
          placeholder="Company website URL"
          class="flex-1 rounded-sm border border-white/10 bg-white px-5 py-4 text-sm text-brand-900 placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-brand-300">

        <a href="#"
          class="inline-flex items-center justify-center rounded-sm bg-brand-300 px-8 py-4 text-sm font-bold text-brand-900 hover:bg-white">
          Generate Report
        </a>
      </div>
    </div>
  </div>
</section>

<section class="bg-brand-50 py-24 sm:py-28">
  <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
    <h2 class="font-serif text-4xl font-medium text-brand-900 sm:text-5xl">
      Valuation FAQ
    </h2>

    <div class="mt-12 divide-y divide-brand-100 border-y border-brand-100">
      <% [
        ["Is this a formal valuation?", "No. This is a preliminary valuation snapshot designed to help owners understand potential value drivers before a formal process."],
        ["What affects my valuation?", "Revenue quality, EBITDA, recurring revenue, customer concentration, growth profile, contracts, market demand, and buyer interest can all affect valuation."],
        ["Do I need to be ready to sell?", "No. Many owners use valuation snapshots to understand options before deciding whether to pursue a sale process."],
        ["Is my information confidential?", "Yes. Information submitted through AcquireTMT is treated confidentially and is not shared with buyers without approval."]
      ].each do |question, answer| %>
        <details class="group py-6">
          <summary class="flex cursor-pointer list-none items-center justify-between gap-6">
            <h3 class="font-serif text-2xl font-medium text-brand-900"><%= question %></h3>
            <span class="shrink-0 transition group-open:rotate-45">
              <%= lucide_icon "plus", class: "h-5 w-5 text-brand-900" %>
            </span>
          </summary>
          <p class="mt-4 max-w-3xl text-base leading-8 text-slate-600"><%= answer %></p>
        </details>
      <% end %>
    </div>
  </div>
</section>