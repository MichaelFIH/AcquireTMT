# Copy to `.env` for local development: `cp .env.example .env`
# `.env` is gitignored. In production these are injected by Kamal
# (see config/deploy.yml + .kamal/secrets), NOT from this file.

# --- Required ----------------------------------------------------------------

# Powers the AI tools (valuation / comps / buyers). Get one at
# https://console.anthropic.com → API Keys. Without it the analyze endpoints
# return 503 "AI engine isn't configured yet".
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Admin area HTTP Basic auth (/admin/leads). In production ADMIN_PASSWORD must
# be set and non-default or the admin area fails closed.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-to-something-strong

# Google sign-in (omniauth). Create an OAuth 2.0 Client (Web application) in
# Google Cloud Console; set the redirect URI to
# http://localhost:3000/auth/google_oauth2/callback (and your prod URL).
# Until these are set, the "Continue with Google" button renders but fails.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Production only (set in the deploy shell / password manager) ------------

# Postgres password for the production database (config/database.yml).
# ACQUIRE_TMT_DATABASE_PASSWORD=

# Rails encrypted-credentials key. Locally this is read from config/master.key.
# RAILS_MASTER_KEY=

# Container registry password (Docker Hub / GHCR / etc.) for image push/pull.
# KAMAL_REGISTRY_PASSWORD=
